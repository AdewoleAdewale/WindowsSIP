<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="SipCoreMobile.Views.AddConferenceParticipantPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:SipCoreMobile.Models"
             Title="Add Conference Participant">

    <Grid RowDefinitions="Auto,*,Auto" Padding="16" RowSpacing="12">

        <SearchBar x:Name="SearchBox" Grid.Row="0" Placeholder="Search contacts" TextChanged="OnSearchTextChanged" />

        <CollectionView x:Name="ContactsList" Grid.Row="1">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:ContactUi">
                    <Grid Padding="12" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnContactTapped" CommandParameter="{Binding .}" />
                        </Grid.GestureRecognizers>

                        <Border Grid.Column="0" StrokeShape="RoundRectangle 22" BackgroundColor="#DCEBFF"
                                WidthRequest="44" HeightRequest="44">
                            <Label Text="{Binding DisplayName, Converter={StaticResource FirstLetterUpperConverter}}"
                                   TextColor="{StaticResource SIPCoreDarkBlue}"
                                   FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>

                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                            <Label Text="{Binding DisplayName}" FontAttributes="Bold" TextColor="{StaticResource SIPCoreTextPrimary}" />
                            <Label Text="{Binding Extension, StringFormat='Ext. {0}'}" FontSize="13" TextColor="{StaticResource SIPCoreTextSecondary}" />
                        </VerticalStackLayout>

                        <Label Grid.Column="2" Text="+" FontSize="22" TextColor="{StaticResource SIPCorePrimary}" VerticalOptions="Center" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Label x:Name="EmptyLabel" Grid.Row="1" Text="No contacts found." TextColor="{StaticResource SIPCoreTextSecondary}"
               Padding="12" IsVisible="False" />

        <Button Grid.Row="2" Text="Close" Clicked="OnCloseClicked" />
    </Grid>
</ContentPage>
