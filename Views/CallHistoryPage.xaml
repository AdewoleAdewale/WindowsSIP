<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="SipCoreMobile.Views.CallHistoryPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:SipCoreMobile.Controls"
             xmlns:models="clr-namespace:SipCoreMobile.Models"
             xmlns:vm="clr-namespace:SipCoreMobile.ViewModels"
             x:DataType="vm:AppStateViewModel"
             BackgroundColor="#F3F5F9"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto, *" Padding="24" RowSpacing="16" WidthRequest="1200" HorizontalOptions="CenterAndExpand">

        <!-- ══════════ 1. HEADER BRAND CARD (Matches Dialer & WorkDesk) ══════════ -->
        <Border Grid.Row="0" 
                BackgroundColor="White" 
                StrokeThickness="1" 
                Stroke="#EAEAEA" 
                Padding="24,20" 
                StrokeShape="RoundRectangle 12">
            <Border.Shadow>
                <Shadow Brush="Black" Opacity="0.04" Radius="8" Offset="0,2"/>
            </Border.Shadow>

            <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto" RowSpacing="12">
                <!-- Left Title Content -->
                <VerticalStackLayout Grid.Column="0" Grid.Row="0" Spacing="4">
                    <Label Text="SIPCORE COMMUNICATIONS" FontSize="11" FontAttributes="Bold" TextColor="{StaticResource SIPCorePrimary}" CharacterSpacing="1.5" />
                    <HorizontalStackLayout Spacing="12">
                        <!-- Back Button -->
                        <Border StrokeShape="RoundRectangle 6" BackgroundColor="#F0F4FA" StrokeThickness="0" WidthRequest="32" HeightRequest="32" VerticalOptions="Center">
                            <Label Text="&#xF060;" FontFamily="MaterialIcons" TextColor="{StaticResource SIPCorePrimary}" FontSize="14" HorizontalOptions="Center" VerticalOptions="Center" />
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnBackTapped" />
                            </Border.GestureRecognizers>
                        </Border>
                        <Label Text="Call History &amp; Analytics" TextColor="{StaticResource SIPCoreDarkBlue}" FontSize="22" FontAttributes="Bold" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>

                <!-- Right Action Buttons -->
                <HorizontalStackLayout Grid.Column="1" Grid.Row="0" Spacing="10" VerticalOptions="Center">
                    <!-- Integrated Log Search Box -->
                    <Border StrokeShape="RoundRectangle 6" StrokeThickness="1" Stroke="#D2D6DC" Padding="12,0" BackgroundColor="#FAFBFD" WidthRequest="240" HeightRequest="38">
                        <Grid ColumnDefinitions="Auto, *">
                            <Label Grid.Column="0" Text="🔍" FontSize="13" Opacity="0.5" VerticalOptions="Center" Margin="0,0,8,0" />
                            <Entry x:Name="SearchBox"
                                   Placeholder="Search calls or extensions..."
                                   TextColor="{StaticResource SIPCoreTextPrimary}" PlaceholderColor="{StaticResource SIPCoreTextSecondary}"
                                   BackgroundColor="Transparent" FontSize="13" VerticalOptions="Center"
                                   TextChanged="OnSearchTextChanged" />
                        </Grid>
                    </Border>

                    <!-- Quick Filter Picker -->
                    <Border StrokeShape="RoundRectangle 6" StrokeThickness="1" Stroke="#D2D6DC" Padding="8,0" BackgroundColor="#FAFBFD" HeightRequest="38">
                        <Picker x:Name="FilterPicker" Title="All calls" SelectedIndex="0" FontSize="12.5" TextColor="{StaticResource SIPCoreTextPrimary}" WidthRequest="110" VerticalOptions="Center">
                            <Picker.Items>
                                <x:String>All calls</x:String>
                                <x:String>Incoming</x:String>
                                <x:String>Outgoing</x:String>
                                <x:String>Missed</x:String>
                            </Picker.Items>
                        </Picker>
                    </Border>

                    <!-- Clear Logs -->
                    <Button Text="Clear logs" Clicked="OnClearLogsClicked"
                            BackgroundColor="#FEEBEE" TextColor="#EF5350" FontSize="12.5" FontAttributes="Bold"
                            HeightRequest="38" Padding="16,0" CornerRadius="6" />
                </HorizontalStackLayout>

                <!-- Subtitle Metadata Summary -->
                <Label Grid.Row="1" Grid.ColumnSpan="2" x:Name="SubtitleLabel" TextColor="{StaticResource SIPCoreTextSecondary}" FontSize="13" />
            </Grid>
        </Border>

        <!-- ══════════ 2. CENTRAL SPLIT LOG CONSOLE ══════════ -->
        <Grid Grid.Row="1" ColumnDefinitions="*, 380" ColumnSpacing="20">

            <!-- LEFT MAIN PANEL: Call History Feed -->
            <Border Grid.Column="0" BackgroundColor="White" StrokeThickness="1" Stroke="#EAEAEA" Padding="24" StrokeShape="RoundRectangle 12">
                <Border.Shadow>
                    <Shadow Brush="Black" Opacity="0.03" Radius="6" Offset="0,2"/>
                </Border.Shadow>

                <Grid RowDefinitions="*">
                    <!-- Collection List of Call Log Entries -->
                    <!-- Make sure your Empty State Border looks like this: -->
                    <Border x:Name="EmptyState" Grid.Row="1" IsVisible="False" >
                        <CollectionView x:Name="CallHistoryList" VerticalScrollBarVisibility="Never">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <!-- Removed strict x:DataType to allow binding to the formatted wrapper -->
                                    <Border StrokeShape="RoundRectangle 6" StrokeThickness="1" Stroke="#EAEAEA" Padding="16,12" BackgroundColor="#FAFBFD">
                                        <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="16">

                                            <!-- Avatar Background Status Trigger -->
                                            <Border Grid.Column="0" WidthRequest="42" HeightRequest="42" StrokeShape="RoundRectangle 21" StrokeThickness="0">
                                                <Border.Triggers>
                                                    <DataTrigger TargetType="Border" Binding="{Binding RawLog.IsMissed}" Value="True">
                                                        <Setter Property="BackgroundColor" Value="#FEEBEE" />
                                                    </DataTrigger>
                                                    <DataTrigger TargetType="Border" Binding="{Binding RawLog.IsMissed}" Value="False">
                                                        <Setter Property="BackgroundColor" Value="#EAF2FF" />
                                                    </DataTrigger>
                                                </Border.Triggers>
                                                <Label Text="{Binding AvatarInitials}" HorizontalOptions="Center" VerticalOptions="Center" FontAttributes="Bold">
                                                    <Label.Triggers>
                                                        <DataTrigger TargetType="Label" Binding="{Binding RawLog.IsMissed}" Value="True">
                                                            <Setter Property="TextColor" Value="#EF5350" />
                                                        </DataTrigger>
                                                        <DataTrigger TargetType="Label" Binding="{Binding RawLog.IsMissed}" Value="False">
                                                            <Setter Property="TextColor" Value="{StaticResource SIPCorePrimary}" />
                                                        </DataTrigger>
                                                    </Label.Triggers>
                                                </Label>
                                            </Border>

                                            <!-- Text Readout Frame -->
                                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                                <HorizontalStackLayout Spacing="8">
                                                    <Label Text="{Binding DisplayName}" FontAttributes="Bold" FontSize="14.5" TextColor="{StaticResource SIPCoreTextPrimary}" />
                                                    <Label Text="{Binding Extension}" FontSize="12.5" TextColor="{StaticResource SIPCoreTextSecondary}" VerticalOptions="Center" />
                                                </HorizontalStackLayout>

                                                <HorizontalStackLayout Spacing="8" Opacity="0.8">
                                                    <Label Text="{Binding DirectionGlyph}" FontFamily="MaterialIcons" FontSize="12" VerticalOptions="Center">
                                                        <Label.Triggers>
                                                            <DataTrigger TargetType="Label" Binding="{Binding RawLog.IsMissed}" Value="True">
                                                                <Setter Property="TextColor" Value="#EF5350" />
                                                            </DataTrigger>
                                                            <DataTrigger TargetType="Label" Binding="{Binding RawLog.IsIncoming}" Value="True">
                                                                <Setter Property="TextColor" Value="#4CAF50" />
                                                            </DataTrigger>
                                                        </Label.Triggers>
                                                    </Label>
                                                    <Label Text="{Binding TimestampText}" FontSize="12" TextColor="{StaticResource SIPCoreTextSecondary}" VerticalOptions="Center" />
                                                    <Label Text="•" FontSize="12" TextColor="{StaticResource SIPCoreTextSecondary}" VerticalOptions="Center" />
                                                    <Label Text="{Binding DurationText}" FontSize="12" TextColor="{StaticResource SIPCoreTextSecondary}" VerticalOptions="Center" />
                                                </HorizontalStackLayout>
                                            </VerticalStackLayout>

                                            <!-- Row Action Buttons (Passes the wrapper's RawLog context parameter to C#) -->
                                            <HorizontalStackLayout Grid.Column="2" Spacing="8" VerticalOptions="Center">
                                                <Button Text="📞" Clicked="OnQuickCallClicked" CommandParameter="{Binding RawLog}"
                WidthRequest="34" HeightRequest="34" CornerRadius="17" Padding="0"
                BackgroundColor="#E8F5E9" TextColor="#4CAF50" />
                                                <Button Text="✕" Clicked="OnDeleteLogClicked" CommandParameter="{Binding RawLog}"
                WidthRequest="34" HeightRequest="34" CornerRadius="17" Padding="0"
                BackgroundColor="#FEEBEE" TextColor="#EF5350" />
                                            </HorizontalStackLayout>

                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </Border>

                    <!-- Update your CollectionView Template to this: -->
                
                </Grid>
            </Border>

            <!-- RIGHT PANEL: Call Diagnostics & Info Card -->
            <Border Grid.Column="1" BackgroundColor="White" StrokeThickness="1" Stroke="#EAEAEA" Padding="24" StrokeShape="RoundRectangle 12">
                <Border.Shadow>
                    <Shadow Brush="Black" Opacity="0.03" Radius="6" Offset="0,2"/>
                </Border.Shadow>

                <VerticalStackLayout Spacing="16">
                    <VerticalStackLayout Spacing="2">
                        <Label Text="CALL STATS" FontSize="11" FontAttributes="Bold" TextColor="{StaticResource SIPCorePrimary}" CharacterSpacing="1.2" />
                        <Label Text="Activity insights" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource SIPCoreDarkBlue}" />
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" Color="#EDEDED" />

                    <!-- Insights indicators grid -->
                    <Grid RowDefinitions="Auto, Auto" ColumnDefinitions="*, *" RowSpacing="10" ColumnSpacing="10">
                        <Border StrokeShape="RoundRectangle 6" BackgroundColor="#FAFBFD" StrokeThickness="1" Stroke="#EAEAEA" Padding="12">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Total Duration" FontSize="11" TextColor="{StaticResource SIPCoreTextSecondary}" />
                                <Label Text="2h 14m" FontAttributes="Bold" FontSize="15" TextColor="{StaticResource SIPCoreDarkBlue}" />
                            </VerticalStackLayout>
                        </Border>

                        <Border StrokeShape="RoundRectangle 6" BackgroundColor="#FAFBFD" StrokeThickness="1" Stroke="#EAEAEA" Padding="12">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Answered" FontSize="11" TextColor="{StaticResource SIPCoreTextSecondary}" />
                                <Label Text="14 calls" FontAttributes="Bold" FontSize="15" TextColor="#4CAF50" />
                            </VerticalStackLayout>
                        </Border>

                        <Border StrokeShape="RoundRectangle 6" BackgroundColor="#FAFBFD" StrokeThickness="1" Stroke="#EAEAEA" Padding="12">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Missed Rate" FontSize="11" TextColor="{StaticResource SIPCoreTextSecondary}" />
                                <Label Text="6.2%" FontAttributes="Bold" FontSize="15" TextColor="#EF5350" />
                            </VerticalStackLayout>
                        </Border>

                        <Border StrokeShape="RoundRectangle 6" BackgroundColor="#FAFBFD" StrokeThickness="1" Stroke="#EAEAEA" Padding="12">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Voicemails" FontSize="11" TextColor="{StaticResource SIPCoreTextSecondary}" />
                                <Label Text="2 pending" FontAttributes="Bold" FontSize="15" TextColor="{StaticResource SIPCorePrimary}" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <BoxView HeightRequest="1" Color="#EDEDED" />

                    <!-- Quick Dialer Entry Shortcut -->
                    <Border StrokeShape="RoundRectangle 6" StrokeThickness="1" Stroke="#EAEAEA" Padding="16" BackgroundColor="#FAFBFD">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Need to place a new call?" FontSize="12.5" FontAttributes="Bold" TextColor="{StaticResource SIPCoreDarkBlue}"/>
                            <Button Text="Open Dialpad Console" Clicked="OnOpenDialpadClicked"
                                    BackgroundColor="{StaticResource SIPCorePrimary}" TextColor="White"
                                    HeightRequest="36" CornerRadius="4" FontSize="12.5" FontAttributes="Bold" />
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </Border>

        </Grid>
    </Grid>
</ContentPage>