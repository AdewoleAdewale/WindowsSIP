<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="SipCoreMobile.Views.LoginPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SipCoreMobile.ViewModels"
             x:DataType="vm:AppStateViewModel"
             x:Name="Root"
             BackgroundColor="{StaticResource SIPCoreBackground}"
             Shell.NavBarIsVisible="False">

    <Grid x:Name="RootGrid" ColumnDefinitions="*,460">

        <!-- ══════════ LEFT: Brand hero (collapses on narrow windows) ══════════ -->
        <Grid x:Name="HeroPane" Grid.Column="0" RowDefinitions="*,Auto" Padding="48">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0E42B3" Offset="0.0" />
                    <GradientStop Color="{StaticResource SIPCorePrimary}" Offset="0.55" />
                    <GradientStop Color="#3D7BFF" Offset="1.0" />
                </LinearGradientBrush>
            </Grid.Background>

            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="20">
                <Border StrokeShape="RoundRectangle 26" StrokeThickness="0"
                        BackgroundColor="White"
                        WidthRequest="104" HeightRequest="104"
                        HorizontalOptions="Center">
                    <Image Source="sipcorelogo.png" WidthRequest="64" HeightRequest="64"
                           Aspect="AspectFit" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>

                <VerticalStackLayout Spacing="8">
                    <Label Text="SIPCore Enterprise"
                           FontSize="34" FontAttributes="Bold" TextColor="White"
                           HorizontalOptions="Center" />
                    <Label Text="Secure, distributed, enterprise-grade communications."
                           FontSize="15" TextColor="#D6E3F8"
                           HorizontalOptions="Center" HorizontalTextAlignment="Center"
                           MaximumWidthRequest="360" LineHeight="1.35" />
                </VerticalStackLayout>

                <!-- Feature ticks -->
                <VerticalStackLayout Spacing="10" Margin="0,20,0,0" HorizontalOptions="Center">
                    <HorizontalStackLayout Spacing="10">
                        <Label Text="✓" TextColor="{StaticResource SIPCoreSignal}" FontSize="14" FontAttributes="Bold" VerticalOptions="Center"/>
                        <Label Text="Encrypted SIP voice and messaging" TextColor="#C4D6F5" FontSize="13" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="10">
                        <Label Text="✓" TextColor="{StaticResource SIPCoreSignal}" FontSize="14" FontAttributes="Bold" VerticalOptions="Center"/>
                        <Label Text="Conference calling and presence" TextColor="#C4D6F5" FontSize="13" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="10">
                        <Label Text="✓" TextColor="{StaticResource SIPCoreSignal}" FontSize="14" FontAttributes="Bold" VerticalOptions="Center"/>
                        <Label Text="WorkDesk tasks and meetings, built in" TextColor="#C4D6F5" FontSize="13" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </VerticalStackLayout>

            <Label Grid.Row="1" Text="Powered by Softworks LLC"
                   TextColor="#8FB2E8" FontSize="12" HorizontalOptions="Center" />
        </Grid>

        <!-- ══════════ RIGHT: Sign-in console ══════════ -->
        <ScrollView x:Name="FormPane" Grid.Column="1" BackgroundColor="{StaticResource SIPCoreCard}">
            <VerticalStackLayout Padding="44,40" Spacing="26" VerticalOptions="Center">

                <VerticalStackLayout Spacing="6">
                    <Label Text="Sign in" FontSize="28" FontAttributes="Bold"
                           TextColor="{StaticResource SIPCoreDarkBlue}"
                           SemanticProperties.HeadingLevel="Level1" />
                    <Label Text="Access your communication workspace"
                           FontSize="14" TextColor="{StaticResource SIPCoreTextSecondary}" />
                </VerticalStackLayout>

                <!-- Extension -->
                <VerticalStackLayout Spacing="8">
                    <Label Text="EXTENSION" FontSize="11" FontAttributes="Bold"
                           CharacterSpacing="1.2" TextColor="{StaticResource SIPCoreTextSecondary}" />
                    <Border x:Name="ExtensionBorder"
                            StrokeShape="RoundRectangle 8" StrokeThickness="1.5"
                            Stroke="{StaticResource SIPCoreBorder}"
                            BackgroundColor="{StaticResource SIPCoreBackground}"
                            Padding="14,2">
                        <Entry x:Name="ExtensionEntry"
                               Placeholder="e.g. 1001"
                               Keyboard="Numeric"
                               ReturnType="Next"
                               FontSize="15"
                               HeightRequest="44"
                               BackgroundColor="Transparent"
                               TextColor="{StaticResource SIPCoreTextPrimary}"
                               PlaceholderColor="{StaticResource SIPCoreTextSecondary}"
                               Completed="OnExtensionCompleted"
                               Focused="OnFieldFocusChanged" Unfocused="OnFieldFocusChanged"
                               SemanticProperties.Description="Extension number" />
                    </Border>
                </VerticalStackLayout>

                <!-- Password -->
                <VerticalStackLayout Spacing="8">
                    <Label Text="PASSWORD" FontSize="11" FontAttributes="Bold"
                           CharacterSpacing="1.2" TextColor="{StaticResource SIPCoreTextSecondary}" />
                    <Border x:Name="PasswordBorder"
                            StrokeShape="RoundRectangle 8" StrokeThickness="1.5"
                            Stroke="{StaticResource SIPCoreBorder}"
                            BackgroundColor="{StaticResource SIPCoreBackground}"
                            Padding="14,2,6,2">
                        <Grid ColumnDefinitions="*,Auto">
                            <Entry x:Name="PasswordEntry"
                                   Placeholder="••••••••"
                                   IsPassword="True"
                                   ReturnType="Go"
                                   FontSize="15"
                                   HeightRequest="44"
                                   BackgroundColor="Transparent"
                                   TextColor="{StaticResource SIPCoreTextPrimary}"
                                   PlaceholderColor="{StaticResource SIPCoreTextSecondary}"
                                   Completed="OnPasswordCompleted"
                                   Focused="OnFieldFocusChanged" Unfocused="OnFieldFocusChanged"
                                   SemanticProperties.Description="Password" />
                            <Button x:Name="RevealButton"
                                    Grid.Column="1"
                                    Text="👁"
                                    FontSize="15"
                                    WidthRequest="38" HeightRequest="38"
                                    Padding="0"
                                    CornerRadius="6"
                                    BackgroundColor="Transparent"
                                    TextColor="{StaticResource SIPCoreTextSecondary}"
                                    Clicked="OnTogglePasswordClicked"
                                    SemanticProperties.Hint="Show or hide password" />
                        </Grid>
                    </Border>
                </VerticalStackLayout>

                <!-- Remember me + server chip -->
                <Grid ColumnDefinitions="*,Auto">
                    <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                        <CheckBox x:Name="RememberMeCheck" IsChecked="True"
                                  Color="{StaticResource SIPCorePrimary}" />
                        <Label Text="Remember me" FontSize="13" VerticalOptions="Center"
                               TextColor="{StaticResource SIPCoreTextPrimary}">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnRememberMeLabelTapped" />
                            </Label.GestureRecognizers>
                        </Label>
                    </HorizontalStackLayout>

                    <Border Grid.Column="1" StrokeThickness="0"
                            StrokeShape="RoundRectangle 12"
                            BackgroundColor="{StaticResource SIPCorePrimaryLight}"
                            Padding="10,5" VerticalOptions="Center">
                        <Label  Text="****************"  FontSize="11.5"
                               TextColor="{StaticResource SIPCorePrimaryDark}" />
                    </Border>
                </Grid>

                <!-- Submit -->
                <Grid Margin="0,6,0,0">
                    <Button x:Name="LoginButton"
                            Text="{Binding IsLoggingIn, Converter={StaticResource LoginButtonTextConverter}}"
                            IsEnabled="{Binding IsLoggingIn, Converter={StaticResource InverseBoolConverter}}"
                            Clicked="OnLoginClicked"
                            BackgroundColor="{StaticResource SIPCorePrimary}"
                            TextColor="White"
                            FontSize="15" FontAttributes="Bold"
                            HeightRequest="46"
                            CornerRadius="8" />
                    <ActivityIndicator IsRunning="{Binding IsLoggingIn}"
                                       IsVisible="{Binding IsLoggingIn}"
                                       Color="White"
                                       WidthRequest="22" HeightRequest="22"
                                       HorizontalOptions="End" VerticalOptions="Center"
                                       Margin="0,0,16,0"
                                       InputTransparent="True" />
                </Grid>

                <!-- Status banner (only when there is a status) -->
                <Border BackgroundColor="#14F04438"
                        Stroke="{StaticResource SIPCoreDanger}" StrokeThickness="0.8"
                        StrokeShape="RoundRectangle 8" Padding="12"
                        IsVisible="{Binding Status, Converter={StaticResource StringNotEmptyConverter}}">
                    <Label Text="{Binding Status}"
                           TextColor="{StaticResource SIPCoreDanger}"
                           FontSize="13" HorizontalTextAlignment="Center" />
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>