<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="SipCoreMobile.Views.LoginPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SipCoreMobile.ViewModels"
             x:DataType="vm:AppStateViewModel"
             x:Name="Root"
             BackgroundColor="{StaticResource SIPCoreBackground}"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False">

    <Grid x:Name="RootGrid" ColumnDefinitions="*, 460">

        <!-- ══════════ LEFT: IMMERSIVE BRAND HERO PANEL ══════════ -->
        <Grid x:Name="HeroPane" Grid.Column="0" RowDefinitions="*, Auto" Padding="48" IsClippedToBounds="True">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#1A0E5C" Offset="0.0"/>
                    <GradientStop Color="{StaticResource SIPCorePrimary}" Offset="0.55"/>
                    <GradientStop Color="#512BD4" Offset="1.0"/>
                </LinearGradientBrush>
            </Grid.Background>

            <!-- Abstract Fluent Art Layer 1 -->
            <Ellipse WidthRequest="600" HeightRequest="600"
                     HorizontalOptions="Start" VerticalOptions="Center"
                     Margin="-150,-150,0,0" Opacity="0.15">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="White" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <!-- Abstract Fluent Art Layer 2 -->
            <Ellipse WidthRequest="500" HeightRequest="500"
                     HorizontalOptions="End" VerticalOptions="End"
                     Margin="0,0,-100,-100" Opacity="0.12">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#7B5FE5" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <!-- Central Brand Content Block -->
            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="24">
                <Border WidthRequest="104" HeightRequest="104"
                        StrokeShape="RoundRectangle 8"
                        BackgroundColor="White"
                        Stroke="Transparent"
                        HorizontalOptions="Center">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,8" Radius="20" Opacity="0.2"/>
                    </Border.Shadow>
                    <Image Source="sipcorelogo.png" WidthRequest="64" HeightRequest="64"
                           Aspect="AspectFit" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>

                <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                    <Label Text="SIPCore Enterprise"
                           FontFamily="OpenSansSemibold"
                           FontSize="38" FontAttributes="Bold" TextColor="White"
                           HorizontalOptions="Center" HorizontalTextAlignment="Center" />
                    <Label Text="The next generation Unified Communications softphone platform."
                           FontFamily="OpenSansRegular"
                           FontSize="15" TextColor="#D6E3F8"
                           HorizontalOptions="Center" HorizontalTextAlignment="Center"
                           MaximumWidthRequest="380" LineHeight="1.35" />
                </VerticalStackLayout>

                <!-- Premium Value Prop Feature List -->
                <VerticalStackLayout Spacing="12" Margin="0,16,0,0" HorizontalOptions="Center">
                    <HorizontalStackLayout Spacing="12">
                        <Label Text="✓" TextColor="{StaticResource SIPCoreSignal}" FontSize="14" FontAttributes="Bold" VerticalOptions="Center"/>
                        <Label Text="Encrypted SIP voice and messaging" TextColor="#C4D6F5" FontSize="13.5" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="12">
                        <Label Text="✓" TextColor="{StaticResource SIPCoreSignal}" FontSize="14" FontAttributes="Bold" VerticalOptions="Center"/>
                        <Label Text="Conference calling and presence" TextColor="#C4D6F5" FontSize="13.5" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="12">
                        <Label Text="✓" TextColor="{StaticResource SIPCoreSignal}" FontSize="14" FontAttributes="Bold" VerticalOptions="Center"/>
                        <Label Text="WorkDesk tasks and meetings, built in" TextColor="#C4D6F5" FontSize="13.5" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </VerticalStackLayout>

            <Label Grid.Row="1" Text="Powered by Softworks LLC  |  v1.0"
                   FontFamily="OpenSansRegular" TextColor="#8FB2E8" FontSize="12" HorizontalOptions="Center" />
        </Grid>

        <!-- ══════════ RIGHT: WINDOWS SIGN-IN CONSOLE ══════════ -->
        <Border Grid.Column="1" StrokeThickness="0" BackgroundColor="{StaticResource SIPCoreCard}">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="-4,0" Radius="25" Opacity="0.1"/>
            </Border.Shadow>

            <ScrollView x:Name="FormPane" VerticalScrollBarVisibility="Never">
                <VerticalStackLayout Padding="40,50" Spacing="28" VerticalOptions="CenterAndExpand">

                    <!-- Welcome Headers -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Sign In" FontSize="30" FontFamily="OpenSansSemibold" FontAttributes="Bold"
                               TextColor="{StaticResource SIPCoreDarkBlue}" SemanticProperties.HeadingLevel="Level1" />
                        <Label Text="Please authenticate your workspace assignment."
                               FontSize="14" FontFamily="OpenSansRegular" TextColor="{StaticResource SIPCoreTextSecondary}" />
                    </VerticalStackLayout>

                    <!-- Input Grid Context -->
                    <VerticalStackLayout Spacing="18">

                        <!-- Extension Field Block -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="EXTENSION NUMBER" FontSize="11" FontAttributes="Bold"
                                   CharacterSpacing="1.2" TextColor="{StaticResource SIPCoreTextSecondary}" />
                            <Border x:Name="ExtensionBorder"
                                    StrokeShape="RoundRectangle 4" StrokeThickness="1"
                                    Stroke="{StaticResource SIPCoreBorder}"
                                    BackgroundColor="{StaticResource SIPCoreBackground}"
                                    HeightRequest="46" Padding="12,0">
                                <Grid ColumnDefinitions="Auto,*">
                                    <Label Grid.Column="0" Text="﹟" FontFamily="OpenSansSemibold" FontSize="16"
                                           TextColor="{StaticResource SIPCorePrimary}" VerticalOptions="Center" Margin="0,0,10,0"/>
                                    <Entry Grid.Column="1" x:Name="ExtensionEntry"
                                           Placeholder="e.g. 1001" Keyboard="Numeric" ReturnType="Next"
                                           FontSize="14" BackgroundColor="Transparent" TextColor="{StaticResource SIPCoreTextPrimary}"
                                           PlaceholderColor="{StaticResource SIPCoreTextSecondary}" Text="{Binding Extension}"
                                           Completed="OnExtensionCompleted" Focused="OnFieldFocusChanged" Unfocused="OnFieldFocusChanged"/>
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Password Field Block -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="SECURE PASSWORD" FontSize="11" FontAttributes="Bold"
                                   CharacterSpacing="1.2" TextColor="{StaticResource SIPCoreTextSecondary}" />
                            <Border x:Name="PasswordBorder"
                                    StrokeShape="RoundRectangle 4" StrokeThickness="1"
                                    Stroke="{StaticResource SIPCoreBorder}"
                                    BackgroundColor="{StaticResource SIPCoreBackground}"
                                    HeightRequest="46" Padding="12,0,4,0">
                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    <Label Grid.Column="0" Text="🔒" FontSize="14" VerticalOptions="Center" Margin="0,0,10,0"/>
                                    <Entry Grid.Column="1" x:Name="PasswordEntry"
                                           Placeholder="••••••••" IsPassword="True" ReturnType="Go"
                                           FontSize="14" BackgroundColor="Transparent" TextColor="{StaticResource SIPCoreTextPrimary}"
                                           PlaceholderColor="{StaticResource SIPCoreTextSecondary}" Text="{Binding Password}"
                                           Completed="OnPasswordCompleted" Focused="OnFieldFocusChanged" Unfocused="OnFieldFocusChanged"/>
                                    <Button Grid.Column="2" x:Name="RevealButton"
                                            Text="👁" FontSize="14" WidthRequest="36" HeightRequest="36" Padding="0" CornerRadius="4"
                                            BackgroundColor="Transparent" TextColor="{StaticResource SIPCoreTextSecondary}"
                                            Clicked="OnTogglePasswordClicked" SemanticProperties.Hint="Show or hide password" />
                                </Grid>
                            </Border>
                        </VerticalStackLayout>
                    </VerticalStackLayout>

                    <!-- Keep Signed In + System Status Indicators -->
                    <Grid ColumnDefinitions="*,Auto">
                        <HorizontalStackLayout Grid.Column="0" Spacing="4" VerticalOptions="Center">
                            <CheckBox x:Name="RememberMeCheck" IsChecked="True" Color="{StaticResource SIPCorePrimary}" Scale="0.85" />
                            <Label Text="Keep me signed in" FontSize="13" FontFamily="OpenSansRegular" 
                                   TextColor="{StaticResource SIPCoreTextSecondary}" VerticalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnRememberMeLabelTapped" />
                                </Label.GestureRecognizers>
                            </Label>
                        </HorizontalStackLayout>

                        <Label Grid.Column="1" Text="Recover Password" FontSize="13" FontFamily="OpenSansSemibold"
                               TextColor="{StaticResource SIPCorePrimary}" VerticalOptions="Center">
                        
                        </Label>
                    </Grid>

                    <!-- Call To Actions (CTA) -->
                    <VerticalStackLayout Spacing="14" Margin="0,6,0,0">
                        <Grid>
                            <Button x:Name="LoginButton"
                                    Text="Authenticate Securely"
                                    Clicked="OnLoginClicked"
                                    BackgroundColor="{StaticResource SIPCorePrimary}"
                                    TextColor="White" FontSize="14" FontAttributes="Bold"
                                    HeightRequest="44" CornerRadius="4"
                                    Command="{Binding LoginCommand}"/>

                            <ActivityIndicator IsRunning="{Binding IsLoggingIn}"
                                               IsVisible="{Binding IsLoggingIn}"
                                               Color="White" WidthRequest="20" HeightRequest="20"
                                               HorizontalOptions="End" VerticalOptions="Center"
                                               Margin="0,0,16,0" InputTransparent="True" />
                        </Grid>

                        <!-- Error Banner (Conditional Layout Context) -->
                        <Border BackgroundColor="#14F04438"
                                Stroke="{StaticResource SIPCoreDanger}" StrokeThickness="0.8"
                                StrokeShape="RoundRectangle 4" Padding="12"
                                IsVisible="{Binding Status, Converter={StaticResource StringNotEmptyConverter}}">
                            <Label Text="{Binding Status}"
                                   TextColor="{StaticResource SIPCoreDanger}"
                                   FontSize="13" HorizontalTextAlignment="Center" />
                        </Border>
                    </VerticalStackLayout>

                  

                </VerticalStackLayout>
            </ScrollView>
        </Border>

    </Grid>
</ContentPage>