<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="SipCoreMobile.Views.WorkDeskTeamPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:SipCoreMobile.Controls"
             BackgroundColor="{StaticResource SIPCoreBackground}"
             Shell.NavBarIsVisible="False">

    <ContentPage.Resources>

        <DataTemplate x:Key="TeamHeaderTemplate" x:DataType="controls:ContactListRowItem">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12" Margin="4,16,4,4">
                <Label Text="{Binding HeaderText}" FontSize="12" FontAttributes="Bold"
                       CharacterSpacing="1.3" TextColor="{StaticResource SIPCoreTextSecondary}"
                       VerticalOptions="Center" />
                <BoxView Grid.Column="1" HeightRequest="1"
                         Color="{StaticResource SIPCoreBorder}" VerticalOptions="Center" />
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="TeamRowTemplate" x:DataType="controls:ContactListRowItem">
            <Border StrokeShape="RoundRectangle 14" StrokeThickness="1"
                    Stroke="{StaticResource SIPCoreBorder}"
                    BackgroundColor="{StaticResource SIPCoreCard}" Padding="14,12">
                <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="14">

                    <!-- Avatar + presence dot -->
                    <Grid Grid.Column="0" WidthRequest="46" HeightRequest="46">
                        <Border StrokeShape="RoundRectangle 23" StrokeThickness="0"
                                BackgroundColor="{StaticResource SIPCorePrimaryLight}">
                            <Label Text="{Binding Initial}"
                                   TextColor="{StaticResource SIPCorePrimaryDark}"
                                   FontAttributes="Bold" FontSize="17"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <Border StrokeShape="RoundRectangle 7"
                                Stroke="{StaticResource SIPCoreCard}" StrokeThickness="2"
                                BackgroundColor="{StaticResource SIPCoreSuccess}"
                                WidthRequest="14" HeightRequest="14"
                                HorizontalOptions="End" VerticalOptions="End"
                                IsVisible="{Binding IsOnline}" />
                    </Grid>

                    <!-- Identity -->
                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                        <Label Text="{Binding DisplayName}" FontAttributes="Bold" FontSize="15"
                               TextColor="{StaticResource SIPCoreTextPrimary}"
                               LineBreakMode="TailTruncation" />
                        <Label Text="{Binding CompanySubtitle}" FontSize="11.5"
                               TextColor="{StaticResource SIPCoreTextSecondary}"
                               IsVisible="{Binding ShowCompanySubtitle}"
                               LineBreakMode="TailTruncation" />
                        <Label Text="{Binding StatusText}" FontSize="12"
                               TextColor="{Binding StatusColor}" />
                    </VerticalStackLayout>

                    <!-- Actions -->
                    <Border Grid.Column="2" StrokeShape="RoundRectangle 19" StrokeThickness="0"
                            BackgroundColor="{StaticResource SIPCoreSignalDim}"
                            WidthRequest="38" HeightRequest="38" VerticalOptions="Center"
                            IsVisible="{Binding Contact.CanCall}">
                        <ImageButton Source="call_icon.png" WidthRequest="16" HeightRequest="16"
                                     Padding="0" BackgroundColor="Transparent"
                                     HorizontalOptions="Center" VerticalOptions="Center"
                                     Clicked="OnCallContactClicked" CommandParameter="{Binding Contact}"
                                     SemanticProperties.Description="Call" />
                    </Border>

                    <Border Grid.Column="3" StrokeShape="RoundRectangle 19" StrokeThickness="0"
                            BackgroundColor="{StaticResource SIPCorePrimaryLight}"
                            WidthRequest="38" HeightRequest="38" VerticalOptions="Center"
                            IsVisible="{Binding Contact.CanMessage}">
                        <ImageButton Source="chat_icon.png" WidthRequest="16" HeightRequest="16"
                                     Padding="0" BackgroundColor="Transparent"
                                     HorizontalOptions="Center" VerticalOptions="Center"
                                     Clicked="OnMessageContactClicked" CommandParameter="{Binding Contact}"
                                     SemanticProperties.Description="Message" />
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>

        <controls:ContactRowTemplateSelector x:Key="TeamRowSelector"
                                             HeaderTemplate="{StaticResource TeamHeaderTemplate}"
                                             ContactTemplate="{StaticResource TeamRowTemplate}" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*" Padding="22,18" MaximumWidthRequest="860" HorizontalOptions="Center">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" ColumnSpacing="14">
            <Border StrokeShape="RoundRectangle 10" StrokeThickness="1"
                    Stroke="{StaticResource SIPCoreBorder}" BackgroundColor="{StaticResource SIPCoreCard}"
                    WidthRequest="40" HeightRequest="40">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackTapped" />
                </Border.GestureRecognizers>
                <Label Text="←" FontSize="16" TextColor="{StaticResource SIPCoreTextSecondary}"
                       HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>
            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                <Label Text="WorkDesk Team" FontSize="21" FontAttributes="Bold"
                       TextColor="{StaticResource SIPCoreDarkBlue}" />
                <Label x:Name="SubtitleLabel" FontSize="12"
                       TextColor="{StaticResource SIPCoreTextSecondary}" />
            </VerticalStackLayout>
        </Grid>

        <!-- List + empty -->
        <Grid Grid.Row="1" Margin="0,14,0,0">
            <Label x:Name="EmptyLabel" Text="No WorkDesk contacts available."
                   TextColor="{StaticResource SIPCoreTextSecondary}" IsVisible="False"
                   HorizontalOptions="Center" VerticalOptions="Center" />
            <CollectionView x:Name="TeamList" ItemTemplate="{StaticResource TeamRowSelector}">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="8" />
                </CollectionView.ItemsLayout>
            </CollectionView>
        </Grid>
    </Grid>
</ContentPage>