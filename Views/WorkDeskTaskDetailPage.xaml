<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="SipCoreMobile.Views.WorkDeskTaskDetailPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:SipCoreMobile.Controls"
             BackgroundColor="{StaticResource SIPCoreDarkBlue}"
             Shell.NavBarIsVisible="False">

    <Grid>
        <ActivityIndicator x:Name="LoadingIndicator" IsRunning="True" Color="{StaticResource SIPCorePrimary}" />

        <ScrollView x:Name="ContentScroll" IsVisible="False">
            <VerticalStackLayout Padding="18" Spacing="16">

                <!-- Header -->
                <HorizontalStackLayout Spacing="12">
                    <Border StrokeShape="RoundRectangle 21" BackgroundColor="#1AFFFFFF" WidthRequest="42" HeightRequest="42">
                        <Label Text="&#xF060;" FontFamily="MaterialIcons" TextColor="White" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center" />
                        <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnBackTapped" /></Border.GestureRecognizers>
                    </Border>
                    <VerticalStackLayout VerticalOptions="Center">
                        <Label Text="Task Details" TextColor="White" FontSize="20" FontAttributes="Bold" />
                        <Label x:Name="SubtitleLabel" TextColor="#A6FFFFFF" FontSize="12" />
                    </VerticalStackLayout>
                </HorizontalStackLayout>

                <!-- Hero card -->
                <Border StrokeShape="RoundRectangle 28" BackgroundColor="#14FFFFFF" Padding="18">
                    <VerticalStackLayout Spacing="6">
                        <Grid ColumnDefinitions="Auto,*">
                            <Border Grid.Column="0" x:Name="HeroIconBg" StrokeShape="RoundRectangle 26" WidthRequest="52" HeightRequest="52">
                                <Label Text="&#xF0AE;" FontFamily="MaterialIcons" x:Name="HeroIcon" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Margin="12,0,0,0" VerticalOptions="Center">
                                <Label x:Name="HeroTitleLabel" TextColor="White" FontAttributes="Bold" FontSize="19" />
                                <Label x:Name="HeroCreatorLabel" TextColor="#9EFFFFFF" FontSize="12" />
                                <Label x:Name="HeroCreatorCompanyLabel" TextColor="#7AFFFFFF" FontSize="11" IsVisible="False" />
                            </VerticalStackLayout>
                        </Grid>

                        <Label x:Name="HeroDescriptionLabel" TextColor="#C2FFFFFF" FontSize="14" Margin="0,10,0,0" />

                        <HorizontalStackLayout Spacing="8" Margin="0,10,0,0">
                            <Border x:Name="HeroStatusChip" StrokeShape="RoundRectangle 50" Padding="10,4">
                                <Label x:Name="HeroStatusLabel" FontSize="11" FontAttributes="Bold" />
                            </Border>
                            <Border x:Name="HeroPriorityChip" StrokeShape="RoundRectangle 50" Padding="10,4">
                                <Label x:Name="HeroPriorityLabel" FontSize="11" FontAttributes="Bold" />
                            </Border>
                            <Border x:Name="HeroApprovalChip" StrokeShape="RoundRectangle 50" Padding="10,4" BackgroundColor="#29A855F7" IsVisible="False">
                                <Label x:Name="HeroApprovalLabel" FontSize="11" FontAttributes="Bold" TextColor="#A855F7" />
                            </Border>
                        </HorizontalStackLayout>

                        <ProgressBar x:Name="HeroProgressBar" HeightRequest="7" Margin="0,12,0,0" />
                        <Label x:Name="HeroProgressLabel" TextColor="#A3FFFFFF" FontSize="11" />
                    </VerticalStackLayout>
                </Border>

                <!-- Actions -->
                <controls:WorkDeskCollapsibleSection x:Name="ActionsSection" Title="Actions" />

                <!-- Remaining sections (populated dynamically) -->
                <controls:WorkDeskCollapsibleSection x:Name="InfoSection" Title="Task Information" />
                <controls:WorkDeskCollapsibleSection x:Name="AssigneesSection" Title="Assignees" />
                <controls:WorkDeskCollapsibleSection x:Name="CommunicationSection" Title="Team Communication" />
                <controls:WorkDeskCollapsibleSection x:Name="CommentsPreviewSection" Title="Recent Comments" />
                <controls:WorkDeskCollapsibleSection x:Name="AttachmentsSection" Title="Attachments" />
                <controls:WorkDeskCollapsibleSection x:Name="ChecklistSection" Title="Checklist" />
                <controls:WorkDeskCollapsibleSection x:Name="WatchersSection" Title="Watchers" />
                <controls:WorkDeskCollapsibleSection x:Name="TimelineSection" Title="Timeline" />

                <BoxView HeightRequest="12" Color="Transparent" />
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
