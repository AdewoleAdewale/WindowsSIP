<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="SipCoreMobile.Views.WorkDeskTaskListPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:SipCoreMobile.Controls"
             xmlns:api="clr-namespace:SipCoreMobile.Models.Api"
             BackgroundColor="{StaticResource SIPCoreBackground}"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,Auto,*" Padding="22,18" MaximumWidthRequest="860" HorizontalOptions="Center">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
            <Border StrokeShape="RoundRectangle 10" StrokeThickness="1"
                    Stroke="{StaticResource SIPCoreBorder}" BackgroundColor="{StaticResource SIPCoreCard}"
                    WidthRequest="40" HeightRequest="40">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackTapped" />
                </Border.GestureRecognizers>
                <Label Text="←" FontSize="16" TextColor="{StaticResource SIPCoreTextSecondary}"
                       HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>

            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                <Label Text="My Tasks" FontSize="21" FontAttributes="Bold"
                       TextColor="{StaticResource SIPCoreDarkBlue}" />
                <Label x:Name="SubtitleLabel" FontSize="12"
                       TextColor="{StaticResource SIPCoreTextSecondary}" />
            </VerticalStackLayout>

            <Border Grid.Column="2" StrokeShape="RoundRectangle 10" StrokeThickness="0"
                    Padding="15,9" VerticalOptions="Center">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0E42B3" Offset="0.0" />
                        <GradientStop Color="{StaticResource SIPCorePrimary}" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Shadow>
                    <Shadow Brush="{StaticResource SIPCorePrimary}" Opacity="0.3" Radius="10" Offset="0,3" />
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnCreateTaskTapped" />
                </Border.GestureRecognizers>
                <HorizontalStackLayout Spacing="7">
                    <Label Text="+" TextColor="White" FontSize="15" FontAttributes="Bold" VerticalOptions="Center" />
                    <Label Text="New task" TextColor="White" FontSize="13" FontAttributes="Bold" VerticalOptions="Center" />
                </HorizontalStackLayout>
            </Border>
        </Grid>

        <!-- Search -->
        <Border Grid.Row="1" StrokeShape="RoundRectangle 10" StrokeThickness="1.2"
                Stroke="{StaticResource SIPCoreBorder}" BackgroundColor="{StaticResource SIPCoreCard}"
                Margin="0,14,0,4" Padding="12,0">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                <Label Text="🔍" FontSize="13" Opacity="0.5" VerticalOptions="Center" />
                <SearchBar Grid.Column="1" x:Name="SearchBox"
                           Placeholder="Search title, status, priority, people…"
                           TextColor="{StaticResource SIPCoreTextPrimary}"
                           PlaceholderColor="{StaticResource SIPCoreTextSecondary}"
                           BackgroundColor="Transparent"
                           TextChanged="OnSearchTextChanged" />
            </Grid>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="2" Margin="0,10,0,0">
            <ActivityIndicator x:Name="LoadingIndicator" IsRunning="False" IsVisible="False"
                               Color="{StaticResource SIPCorePrimary}" WidthRequest="30" HeightRequest="30"
                               HorizontalOptions="Center" VerticalOptions="Center" />

            <VerticalStackLayout x:Name="EmptyState" IsVisible="False"
                                 HorizontalOptions="Center" VerticalOptions="Center"
                                 Spacing="10" Padding="30">
                <Label Text="🗂" FontSize="38" Opacity="0.35" HorizontalOptions="Center" />
                <Label x:Name="EmptyTitleLabel" FontSize="16" FontAttributes="Bold"
                       TextColor="{StaticResource SIPCoreTextPrimary}" HorizontalOptions="Center" />
                <Label x:Name="EmptyMessageLabel" FontSize="13"
                       TextColor="{StaticResource SIPCoreTextSecondary}"
                       HorizontalTextAlignment="Center" MaximumWidthRequest="320" />
            </VerticalStackLayout>

            <CollectionView x:Name="TasksList">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="api:WorkTaskDto">
                        <controls:WorkDeskTaskCard Loaded="OnCardLoaded" />
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </Grid>
</ContentPage>