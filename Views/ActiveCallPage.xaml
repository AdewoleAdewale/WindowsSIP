<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="SipCoreMobile.Views.ActiveCallPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:SipCoreMobile.Controls"
             xmlns:vm="clr-namespace:SipCoreMobile.ViewModels"
             x:DataType="vm:AppStateViewModel"
             BackgroundColor="{StaticResource SIPCoreDarkBlue}"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="0">

            <HorizontalStackLayout HorizontalOptions="Center" Spacing="8" Margin="0,28,0,26">
                <controls:StatusPulseDot IsLive="True" VerticalOptions="Center" />
                <Label Text="{Binding Status}" TextColor="#D1FFFFFF" FontSize="17" FontAttributes="Bold" />
            </HorizontalStackLayout>

            <Border StrokeShape="RoundRectangle 61" BackgroundColor="White"
                    WidthRequest="122" HeightRequest="122" HorizontalOptions="Center">
                <Image Source="sipcorelogo.png" WidthRequest="76" HeightRequest="76" Aspect="AspectFit"
                       HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>

            <Label Text="{Binding ActiveNumber, Converter={StaticResource DisplayNamePartConverter}}"
                   TextColor="White" FontSize="32" FontAttributes="Bold"
                   HorizontalTextAlignment="Center" MaxLines="2" LineBreakMode="TailTruncation"
                   Margin="0,24,0,0" />

            <Label Text="{Binding ActiveNumber, Converter={StaticResource ExtensionPartConverter}, StringFormat='({0})'}"
                   TextColor="#D9FFFFFF" FontSize="22" HorizontalTextAlignment="Center"
                   IsVisible="{Binding ActiveNumber, Converter={StaticResource StringNotEmptyConverter}}"
                   Margin="0,4,0,0" />

            <Label Text="{Binding CallDurationSeconds, Converter={StaticResource DurationFormatConverter}}"
                   TextColor="#D1FFFFFF" FontSize="18" FontAttributes="Bold"
                   HorizontalOptions="Center" Margin="0,14,0,0" />

            <!-- Conference participants -->
            <Border x:Name="ConferenceCard" StrokeShape="RoundRectangle 22" BackgroundColor="#1AFFFFFF"
                    Padding="16" Margin="0,20,0,0" IsVisible="False">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Conference Participants" TextColor="#D9FFFFFF" FontSize="14" FontAttributes="Bold" />
                    <CollectionView x:Name="ConferenceList" ItemsSource="{Binding ConferenceParticipants}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <Grid Padding="12,10" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10"
                                      BackgroundColor="#14FFFFFF">
                                    <Ellipse Grid.Column="0" Fill="{StaticResource SIPCoreSuccess}" WidthRequest="10" HeightRequest="10" VerticalOptions="Center" />
                                    <Label Grid.Column="1" Text="{Binding .}" TextColor="White" FontSize="14"
                                           LineBreakMode="TailTruncation" VerticalOptions="Center" />
                                    <ImageButton Grid.Column="2" Source="end.png" WidthRequest="22" HeightRequest="22"
                                                 BackgroundColor="Transparent"
                                                 Clicked="OnRemoveParticipantClicked"
                                                 CommandParameter="{Binding .}" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <!-- Call controls -->
            <Grid ColumnDefinitions="*,*,*,*" Margin="0,26,0,0">
                <controls:CallControlButton x:Name="MuteButton" Grid.Column="0" Icon="&#xF131;" Label="Mute" Tapped="OnMuteTapped" />
                <controls:CallControlButton x:Name="SpeakerButton" Grid.Column="1" Icon="&#xF028;" Label="Speaker" Tapped="OnSpeakerTapped" />
                <controls:CallControlButton x:Name="HoldButton" Grid.Column="2" Icon="&#xF04C;" Label="Hold" Tapped="OnHoldTapped" />
                <controls:CallControlButton x:Name="KeypadButton" Grid.Column="3" Icon="&#xF095;" Label="Keypad" Tapped="OnKeypadTapped" />
            </Grid>

            <controls:DtmfDialpad x:Name="Dialpad" IsVisible="False" DigitPressed="OnDtmfDigitPressed" Margin="0,20,0,0" />

            <Button Text="Add participant from contacts" Clicked="OnAddParticipantClicked"
                    BackgroundColor="{StaticResource SIPCorePrimary}" TextColor="White"
                    CornerRadius="18" Margin="0,24,0,0" />

            <Border StrokeShape="RoundRectangle 42" WidthRequest="84" HeightRequest="84"
                    BackgroundColor="White" HorizontalOptions="Center" Margin="0,40,0,22">
                <Image Source="end.png" WidthRequest="42" HeightRequest="42" />
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnHangupTapped" />
                </Border.GestureRecognizers>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
