<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="SipCoreMobile.Views.MeetingDetailPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:SipCoreMobile.Controls"
             xmlns:vm="clr-namespace:SipCoreMobile.ViewModels"
             x:DataType="vm:MeetingsViewModel"
             BackgroundColor="{StaticResource SIPCoreBackground}"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <Grid Padding="18" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">

            <VerticalStackLayout Grid.Row="0" Spacing="2">
                <Label x:Name="TitleLabel" FontSize="24" FontAttributes="Bold" TextColor="{StaticResource SIPCoreDarkBlue}" />
                <Label x:Name="MeetingIdLabel" FontSize="12" TextColor="{StaticResource SIPCoreTextSecondary}" />
            </VerticalStackLayout>

            <!-- Conference info card -->
            <Border Grid.Row="1" StrokeShape="RoundRectangle 22" BackgroundColor="White" Padding="18" Margin="0,14,0,0">
                <VerticalStackLayout Spacing="4">
                    <Label Text="Conference Number" FontSize="13" TextColor="{StaticResource SIPCoreTextSecondary}" />
                    <Label x:Name="ConferenceNumberLabel" FontSize="32" FontAttributes="Bold" TextColor="{StaticResource SIPCoreDarkBlue}" />
                    <controls:MeetingStatusBadge x:Name="StatusBadge" Margin="0,6,0,0" HorizontalOptions="Start" />
                    <Label x:Name="ParticipantPinLabel" FontSize="13" TextColor="{StaticResource SIPCoreTextSecondary}" Margin="0,6,0,0" />
                </VerticalStackLayout>
            </Border>

            <Button Grid.Row="2" Text="Join Meeting" Clicked="OnJoinClicked"
                    BackgroundColor="{StaticResource SIPCorePrimary}" TextColor="White" CornerRadius="16" Margin="0,14,0,0" />

            <!-- Host controls -->
            <VerticalStackLayout x:Name="HostControls" Grid.Row="3" Margin="0,10,0,0" IsVisible="False">
                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <Button Grid.Column="0" Text="Start" Clicked="OnStartClicked"
                            BackgroundColor="Transparent" TextColor="{StaticResource SIPCorePrimary}"
                            BorderColor="{StaticResource SIPCorePrimary}" BorderWidth="1" CornerRadius="14" />
                    <Button Grid.Column="1" Text="End" Clicked="OnEndClicked"
                            BackgroundColor="Transparent" TextColor="{StaticResource SIPCoreDanger}"
                            BorderColor="{StaticResource SIPCoreDanger}" BorderWidth="1" CornerRadius="14" />
                </Grid>
                <Grid ColumnDefinitions="*,*" ColumnSpacing="8" Margin="0,8,0,0">
                    <Button Grid.Column="0" Text="Lock" Clicked="OnLockClicked"
                            BackgroundColor="Transparent" TextColor="{StaticResource SIPCorePrimary}"
                            BorderColor="{StaticResource SIPCorePrimary}" BorderWidth="1" CornerRadius="14" />
                    <Button Grid.Column="1" Text="Unlock" Clicked="OnUnlockClicked"
                            BackgroundColor="Transparent" TextColor="{StaticResource SIPCorePrimary}"
                            BorderColor="{StaticResource SIPCorePrimary}" BorderWidth="1" CornerRadius="14" />
                </Grid>
            </VerticalStackLayout>

            <!-- Live members -->
            <Border Grid.Row="4" StrokeShape="RoundRectangle 20" BackgroundColor="White" Padding="16" Margin="0,14,0,0">
                <VerticalStackLayout Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="Live Members" FontAttributes="Bold" TextColor="{StaticResource SIPCoreDarkBlue}" VerticalOptions="Center" />
                        <Button Grid.Column="1" Text="Refresh" Clicked="OnRefreshLiveClicked"
                                BackgroundColor="Transparent" TextColor="{StaticResource SIPCorePrimary}" Padding="8,0" />
                    </Grid>
                    <Label x:Name="LiveMembersLabel" FontSize="13" TextColor="{StaticResource SIPCoreTextSecondary}" />
                </VerticalStackLayout>
            </Border>

            <Button Grid.Row="5" Text="Back" Clicked="OnBackClicked"
                    BackgroundColor="Transparent" TextColor="{StaticResource SIPCorePrimary}"
                    BorderColor="{StaticResource SIPCorePrimary}" BorderWidth="1" CornerRadius="14" Margin="0,12,0,0" />

        </Grid>
    </ScrollView>
</ContentPage>
