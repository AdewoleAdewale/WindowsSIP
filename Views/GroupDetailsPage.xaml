<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="SipCoreMobile.Views.GroupDetailsPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:SipCoreMobile.Models"
             xmlns:vm="clr-namespace:SipCoreMobile.ViewModels"
             x:DataType="vm:GroupsViewModel"
             BackgroundColor="{StaticResource SIPCoreBackground}"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,Auto,Auto,*">

        <!-- Header -->
        <Grid Grid.Row="0" BackgroundColor="White" Padding="16,14" ColumnDefinitions="Auto,*,Auto">
            <ImageButton Grid.Column="0" Source="back_icon.png" WidthRequest="26" HeightRequest="26"
                         BackgroundColor="Transparent" Clicked="OnBackClicked" />

            <VerticalStackLayout Grid.Column="1" Margin="12,0,0,0">
                <Label x:Name="GroupNameLabel" FontSize="24" FontAttributes="Bold" TextColor="{StaticResource SIPCoreDarkBlue}" />
                <Label x:Name="MemberCountLabel" TextColor="{StaticResource SIPCoreTextSecondary}" />
            </VerticalStackLayout>

            <ImageButton Grid.Column="2" Source="add_person_icon.png" WidthRequest="26" HeightRequest="26"
                         BackgroundColor="Transparent" Clicked="OnAddMemberClicked" />
        </Grid>

        <!-- Call / Group Chat buttons -->
        <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="12" Padding="20,18,20,0">
            <Button Grid.Column="0" Text="Call Group" Clicked="OnCallGroupClicked"
                    BackgroundColor="{StaticResource SIPCorePrimary}" TextColor="White" CornerRadius="16" />
            <Button Grid.Column="1" Text="Group Chat" Clicked="OnGroupChatClicked"
                    BackgroundColor="Transparent" TextColor="{StaticResource SIPCorePrimary}"
                    BorderColor="{StaticResource SIPCorePrimary}" BorderWidth="1" CornerRadius="16" />
        </Grid>

        <Label Grid.Row="2" Text="Members" FontSize="22" FontAttributes="Bold"
               TextColor="{StaticResource SIPCoreTextPrimary}" Margin="20,20,20,12" />

        <Grid Grid.Row="3">
            <CollectionView x:Name="MembersList"  ItemsSource="{Binding SelectedGroupMembers}">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="12" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:GroupMemberUi">
                        <Border StrokeShape="RoundRectangle 18" BackgroundColor="White" Padding="16">
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                                <Border Grid.Column="0" StrokeShape="RoundRectangle 25" BackgroundColor="#DCEBFF"
                                        WidthRequest="50" HeightRequest="50">
                                    <Label Text="{Binding DisplayName, Converter={StaticResource FirstLetterUpperConverter}}"
                                           TextColor="{StaticResource SIPCoreDarkBlue}" FontAttributes="Bold"
                                           HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>

                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                    <Label Text="{Binding DisplayName}" FontAttributes="Bold" TextColor="{StaticResource SIPCoreTextPrimary}" />
                                    <Label Text="{Binding Extension, StringFormat='Ext. {0}'}" TextColor="{StaticResource SIPCoreTextSecondary}" />
                                </VerticalStackLayout>

                                <ImageButton Grid.Column="2" Source="remove_circle_icon.png" WidthRequest="24" HeightRequest="24"
                                             BackgroundColor="Transparent"
                                             Clicked="OnRemoveMemberClicked" CommandParameter="{Binding Extension}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label x:Name="EmptyMembersLabel" Text="No members yet. Tap + to add contacts."
                   TextColor="{StaticResource SIPCoreTextSecondary}" Margin="20,8" IsVisible="False" />
        </Grid>

    </Grid>
</ContentPage>
