<?xml version="1.0" encoding="utf-8" ?>

<ContentPage x:Class="SipCoreMobile.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:SipCoreMobile.Controls"
             xmlns:vm="clr-namespace:SipCoreMobile.ViewModels"
             x:DataType="vm:AppStateViewModel"
             BackgroundColor="{StaticResource SIPCoreBackground}"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,Auto,Auto,*">

        <controls:SipCoreHeader Grid.Row="0" DrawerRequested="OnDrawerRequested" />

        <VerticalStackLayout Grid.Row="1" Padding="20,16,20,12" Spacing="4">
            <Label Text="Settings" FontSize="28" FontAttributes="Bold" TextColor="{StaticResource SIPCoreTextPrimary}" />
            <Label x:Name="ExtensionLabel" TextColor="{StaticResource SIPCoreTextSecondary}" FontSize="14" />
        </VerticalStackLayout>

        <!-- Tabs -->
        <Grid Grid.Row="2" BackgroundColor="White" ColumnDefinitions="*,*,*,*" Padding="0,4">
            <Button x:Name="PasswordTabButton" Grid.Column="0" Text="Password" FontSize="12" FontAttributes="Bold"
                    BackgroundColor="Transparent" Clicked="OnPasswordTabClicked" />
            <Button x:Name="OutboundTabButton" Grid.Column="1" Text="Outbound" FontSize="12" FontAttributes="Bold"
                    BackgroundColor="Transparent" Clicked="OnOutboundTabClicked" />
            <Button x:Name="VoicemailTabButton" Grid.Column="2" Text="Voicemail" FontSize="12" FontAttributes="Bold"
                    BackgroundColor="Transparent" Clicked="OnVoicemailTabClicked" />
            <Button x:Name="PremiumTabButton" Grid.Column="3" Text="Premium" FontSize="12" FontAttributes="Bold"
                    BackgroundColor="Transparent" Clicked="OnPremiumTabClicked" />
        </Grid>

        <ScrollView Grid.Row="3">
            <Grid Padding="20">

                <!-- Password tab -->
                <VerticalStackLayout x:Name="PasswordTab" Spacing="14">
                    <Label Text="Change Password" FontSize="22" FontAttributes="Bold" TextColor="{StaticResource SIPCoreTextPrimary}" />
                    <Entry x:Name="CurrentPasswordEntry" Placeholder="Current Password" IsPassword="True" />
                    <Entry x:Name="NewPasswordEntry" Placeholder="New Password" IsPassword="True" />
                    <Entry x:Name="ConfirmPasswordEntry" Placeholder="Confirm Password" IsPassword="True" />
                    <Button Text="Change Password" Clicked="OnChangePasswordClicked"
                            BackgroundColor="{StaticResource SIPCorePrimary}" TextColor="White" CornerRadius="16" Margin="0,10,0,0" />
                </VerticalStackLayout>

                <!-- Outbound tab -->
                <VerticalStackLayout x:Name="OutboundTab" Spacing="14" IsVisible="False">
                    <Label Text="Outbound Number / PSTN" FontSize="22" FontAttributes="Bold" TextColor="{StaticResource SIPCoreTextPrimary}" />
                    <Label x:Name="OutboundDescriptionLabel" TextColor="{StaticResource SIPCoreTextSecondary}" />

                    <VerticalStackLayout x:Name="OutboundActiveState" IsVisible="False" Spacing="8">
                        <HorizontalStackLayout Spacing="8">
                            <Ellipse Fill="{StaticResource SIPCoreSuccess}" WidthRequest="9" HeightRequest="9" VerticalOptions="Center" />
                            <Label Text="Active" TextColor="{StaticResource SIPCoreSuccess}" FontAttributes="Bold" FontSize="14" />
                        </HorizontalStackLayout>
                        <Label Text="Assigned Outbound Number" TextColor="{StaticResource SIPCoreTextSecondary}" Margin="0,10,0,0" />
                        <Label x:Name="OutboundNumberLabel" FontSize="26" FontAttributes="Bold" TextColor="{StaticResource SIPCoreTextPrimary}" />
                        <Label Text="This number will be used when you call external PSTN numbers."
                               TextColor="{StaticResource SIPCoreTextSecondary}" Margin="0,10,0,0" />
                    </VerticalStackLayout>

                    <VerticalStackLayout x:Name="OutboundInactiveState" Spacing="14">
                        <Entry x:Name="ActivationCodeEntry" Placeholder="SIPCore Activation Code (e.g. SIP-123456)" />
                        <Button Text="Activate Outbound Number" Clicked="OnActivateOutboundClicked"
                                BackgroundColor="{StaticResource SIPCorePrimary}" TextColor="White" CornerRadius="16" />
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <!-- Voicemail tab -->
                <VerticalStackLayout x:Name="VoicemailTab" Spacing="18" IsVisible="False">
                    <Label Text="Voicemail" FontSize="22" FontAttributes="Bold" TextColor="{StaticResource SIPCoreTextPrimary}" />
                    <controls:SettingsSwitchRow x:Name="VoicemailSwitch" Title="Enable Voicemail"
                                                 Description="Unanswered calls will be sent to voicemail."
                                                 Toggled="OnVoicemailToggled" />
                </VerticalStackLayout>

                <!-- Premium tab -->
                <VerticalStackLayout x:Name="PremiumTab" Spacing="14" IsVisible="False">
                    <Label Text="Premium Features" FontSize="22" FontAttributes="Bold" TextColor="{StaticResource SIPCoreTextPrimary}" />
                    <Label Text="Call recording is a premium SIPCore feature." TextColor="{StaticResource SIPCoreTextSecondary}" />

                    <controls:SettingsSwitchRow x:Name="CallRecordingSwitch" IsVisible="False"
                                                 Title="Enable Voice Recording"
                                                 Description="Record incoming and outgoing calls."
                                                 Toggled="OnCallRecordingToggled" />

                    <VerticalStackLayout x:Name="UpgradePrompt" Spacing="10">
                        <Button Text="Upgrade to Premium" Clicked="OnUpgradePremiumClicked"
                                BackgroundColor="{StaticResource SIPCorePrimary}" TextColor="White" CornerRadius="16" />
                        <Label Text="Upgrade is required before voice recording can be enabled."
                               TextColor="{StaticResource SIPCoreTextSecondary}" />
                    </VerticalStackLayout>
                </VerticalStackLayout>

            </Grid>
        </ScrollView>
    </Grid>
</ContentPage>
