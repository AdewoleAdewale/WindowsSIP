<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="SipCoreMobile.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:SipCoreMobile.Controls"
             xmlns:vm="clr-namespace:SipCoreMobile.ViewModels"
             x:DataType="vm:AppStateViewModel"
             BackgroundColor="{StaticResource SIPCoreBackground}"
             Shell.NavBarIsVisible="False">

    <ContentPage.Resources>
        <Style x:Key="FieldBorder" TargetType="Border">
            <Setter Property="StrokeShape" Value="RoundRectangle 10" />
            <Setter Property="StrokeThickness" Value="1.2" />
            <Setter Property="Stroke" Value="{StaticResource SIPCoreBorder}" />
            <Setter Property="BackgroundColor" Value="{StaticResource SIPCoreCard}" />
            <Setter Property="Padding" Value="14,2" />
        </Style>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,Auto,Auto,*">

        <controls:SipCoreHeader Grid.Row="0" DrawerRequested="OnDrawerRequested" />

        <!-- Title band with soft gradient -->
        <Border Grid.Row="1" StrokeThickness="0" Padding="22,18,22,16">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#F7F8FC" Offset="0.0" />
                    <GradientStop Color="#EDF3FF" Offset="1.0" />
                </LinearGradientBrush>
            </Border.Background>
            <VerticalStackLayout Spacing="3">
                <Label Text="Settings" FontSize="26" FontAttributes="Bold"
                       TextColor="{StaticResource SIPCoreDarkBlue}" />
                <Label x:Name="ExtensionLabel" FontSize="13"
                       TextColor="{StaticResource SIPCoreTextSecondary}" />
            </VerticalStackLayout>
        </Border>

        <!-- Segmented tabs -->
        <Border Grid.Row="2" StrokeShape="RoundRectangle 12" StrokeThickness="1"
                Stroke="{StaticResource SIPCoreBorder}" BackgroundColor="{StaticResource SIPCoreCard}"
                Margin="22,0,22,0" Padding="4">
            <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="4">
                <Button x:Name="PasswordTabButton" Grid.Column="0" Text="Password"
                        FontSize="12.5" FontAttributes="Bold" CornerRadius="8" HeightRequest="38"
                        BackgroundColor="Transparent" Clicked="OnPasswordTabClicked" />
                <Button x:Name="OutboundTabButton" Grid.Column="1" Text="Outbound"
                        FontSize="12.5" FontAttributes="Bold" CornerRadius="8" HeightRequest="38"
                        BackgroundColor="Transparent" Clicked="OnOutboundTabClicked" />
                <Button x:Name="VoicemailTabButton" Grid.Column="2" Text="Voicemail"
                        FontSize="12.5" FontAttributes="Bold" CornerRadius="8" HeightRequest="38"
                        BackgroundColor="Transparent" Clicked="OnVoicemailTabClicked" />
                <Button x:Name="PremiumTabButton" Grid.Column="3" Text="Premium"
                        FontSize="12.5" FontAttributes="Bold" CornerRadius="8" HeightRequest="38"
                        BackgroundColor="Transparent" Clicked="OnPremiumTabClicked" />
            </Grid>
        </Border>

        <ScrollView Grid.Row="3">
            <Grid Padding="22,18,22,30" MaximumWidthRequest="640" HorizontalOptions="Center">

                <!-- Password tab -->
                <VerticalStackLayout x:Name="PasswordTab" Spacing="14">
                    <Label Text="Change Password" FontSize="20" FontAttributes="Bold"
                           TextColor="{StaticResource SIPCoreDarkBlue}" />
                    <Border Style="{StaticResource FieldBorder}">
                        <Entry x:Name="CurrentPasswordEntry" Placeholder="Current Password" IsPassword="True"
                               HeightRequest="44" BackgroundColor="Transparent" />
                    </Border>
                    <Border Style="{StaticResource FieldBorder}">
                        <Entry x:Name="NewPasswordEntry" Placeholder="New Password" IsPassword="True"
                               HeightRequest="44" BackgroundColor="Transparent" />
                    </Border>
                    <Border Style="{StaticResource FieldBorder}">
                        <Entry x:Name="ConfirmPasswordEntry" Placeholder="Confirm Password" IsPassword="True"
                               HeightRequest="44" BackgroundColor="Transparent" />
                    </Border>
                    <Button Text="Change Password" Clicked="OnChangePasswordClicked"
                            BackgroundColor="{StaticResource SIPCorePrimary}" TextColor="White"
                            FontAttributes="Bold" HeightRequest="46" CornerRadius="10" Margin="0,8,0,0" />
                </VerticalStackLayout>

                <!-- Outbound tab -->
                <VerticalStackLayout x:Name="OutboundTab" Spacing="14" IsVisible="False">
                    <Label Text="Outbound Number / PSTN" FontSize="20" FontAttributes="Bold"
                           TextColor="{StaticResource SIPCoreDarkBlue}" />
                    <Label x:Name="OutboundDescriptionLabel" FontSize="13.5"
                           TextColor="{StaticResource SIPCoreTextSecondary}" />

                    <VerticalStackLayout x:Name="OutboundActiveState" IsVisible="False" Spacing="8">
                        <Border StrokeShape="RoundRectangle 14" StrokeThickness="1"
                                Stroke="{StaticResource SIPCoreBorder}" BackgroundColor="{StaticResource SIPCoreCard}"
                                Padding="20,16">
                            <VerticalStackLayout Spacing="8">
                                <HorizontalStackLayout Spacing="8">
                                    <Ellipse Fill="{StaticResource SIPCoreSuccess}" WidthRequest="9" HeightRequest="9" VerticalOptions="Center" />
                                    <Label Text="Active" TextColor="{StaticResource SIPCoreSuccess}"
                                           FontAttributes="Bold" FontSize="13" VerticalOptions="Center" />
                                </HorizontalStackLayout>
                                <Label Text="ASSIGNED OUTBOUND NUMBER" FontSize="10.5" FontAttributes="Bold"
                                       CharacterSpacing="1.3" TextColor="{StaticResource SIPCoreTextSecondary}"
                                       Margin="0,8,0,0" />
                                <Label x:Name="OutboundNumberLabel" FontSize="26" FontAttributes="Bold"
                                       TextColor="{StaticResource SIPCoreDarkBlue}" />
                                <Label Text="This number will be used when you call external PSTN numbers."
                                       FontSize="12.5" TextColor="{StaticResource SIPCoreTextSecondary}" />
                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout x:Name="OutboundInactiveState" Spacing="14">
                        <Border Style="{StaticResource FieldBorder}">
                            <Entry x:Name="ActivationCodeEntry" Placeholder="SIPCore Activation Code (e.g. SIP-123456)"
                                   HeightRequest="44" BackgroundColor="Transparent" />
                        </Border>
                        <Button Text="Activate Outbound Number" Clicked="OnActivateOutboundClicked"
                                BackgroundColor="{StaticResource SIPCorePrimary}" TextColor="White"
                                FontAttributes="Bold" HeightRequest="46" CornerRadius="10" />
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <!-- Voicemail tab -->
                <VerticalStackLayout x:Name="VoicemailTab" Spacing="16" IsVisible="False">
                    <Label Text="Voicemail" FontSize="20" FontAttributes="Bold"
                           TextColor="{StaticResource SIPCoreDarkBlue}" />
                    <controls:SettingsSwitchRow x:Name="VoicemailSwitch" Title="Enable Voicemail"
                                                Description="Unanswered calls will be sent to voicemail."
                                                Toggled="OnVoicemailToggled" />
                </VerticalStackLayout>

                <!-- Premium tab -->
                <VerticalStackLayout x:Name="PremiumTab" Spacing="14" IsVisible="False">
                    <Label Text="Premium Features" FontSize="20" FontAttributes="Bold"
                           TextColor="{StaticResource SIPCoreDarkBlue}" />
                    <Label Text="Call recording is a premium SIPCore feature."
                           FontSize="13.5" TextColor="{StaticResource SIPCoreTextSecondary}" />

                    <controls:SettingsSwitchRow x:Name="CallRecordingSwitch" IsVisible="False"
                                                Title="Enable Voice Recording"
                                                Description="Record incoming and outgoing calls."
                                                Toggled="OnCallRecordingToggled" />

                    <VerticalStackLayout x:Name="UpgradePrompt" Spacing="10">
                        <Border StrokeShape="RoundRectangle 12" StrokeThickness="0" HeightRequest="46">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#0E42B3" Offset="0.0" />
                                    <GradientStop Color="{StaticResource SIPCorePrimary}" Offset="1.0" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnUpgradePremiumClicked" />
                            </Border.GestureRecognizers>
                            <Label Text="★  Upgrade to Premium" TextColor="White" FontSize="14" FontAttributes="Bold"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <Label Text="Upgrade is required before voice recording can be enabled."
                               FontSize="12.5" TextColor="{StaticResource SIPCoreTextSecondary}" />
                    </VerticalStackLayout>
                </VerticalStackLayout>

            </Grid>
        </ScrollView>
    </Grid>
</ContentPage>