<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="SipCoreMobile.Views.WorkDeskApprovalsPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:api="clr-namespace:SipCoreMobile.Models.Api"
             xmlns:vm="clr-namespace:SipCoreMobile.ViewModels"
             x:DataType="vm:WorkDeskViewModel"
             BackgroundColor="{StaticResource SIPCoreDarkBlue}"
             Shell.NavBarIsVisible="False">

    <Grid Padding="18" RowDefinitions="Auto,Auto,*">

        <HorizontalStackLayout Grid.Row="0" Spacing="12">
            <Border StrokeShape="RoundRectangle 21" BackgroundColor="#1AFFFFFF" WidthRequest="42" HeightRequest="42">
                <Label Text="&#xF060;" FontFamily="MaterialIcons" TextColor="White" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center" />
                <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnBackTapped" /></Border.GestureRecognizers>
            </Border>
            <VerticalStackLayout VerticalOptions="Center">
                <Label Text="Approval Center" TextColor="White" FontSize="20" FontAttributes="Bold" />
                <Label x:Name="SubtitleLabel" TextColor="#A6FFFFFF" FontSize="12" />
            </VerticalStackLayout>
        </HorizontalStackLayout>

        <!-- Summary card -->
        <Border Grid.Row="1" StrokeShape="RoundRectangle 26" BackgroundColor="#14FFFFFF" Padding="18" Margin="0,16,0,0">
            <Grid ColumnDefinitions="*,*,*">
                <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center">
                    <Label x:Name="PendingValue" TextColor="#F59E0B" FontSize="22" FontAttributes="Bold" HorizontalOptions="Center" />
                    <Label Text="Pending" TextColor="#A8FFFFFF" FontSize="12" HorizontalOptions="Center" />
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center">
                    <Label x:Name="ApprovedValue" TextColor="#22C55E" FontSize="22" FontAttributes="Bold" HorizontalOptions="Center" />
                    <Label Text="Approved" TextColor="#A8FFFFFF" FontSize="12" HorizontalOptions="Center" />
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center">
                    <Label x:Name="RejectedValue" TextColor="#EF4444" FontSize="22" FontAttributes="Bold" HorizontalOptions="Center" />
                    <Label Text="Rejected" TextColor="#A8FFFFFF" FontSize="12" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,16,0,0">
            <ActivityIndicator x:Name="LoadingIndicator" IsRunning="False" IsVisible="False" Color="{StaticResource SIPCorePrimary}" />

            <VerticalStackLayout x:Name="EmptyState" IsVisible="False" HorizontalOptions="Center" VerticalOptions="Center" Spacing="8" Padding="24">
                <Label Text="&#xF058;" FontFamily="MaterialIcons" FontSize="34" TextColor="#B8FFFFFF" HorizontalOptions="Center" />
                <Label x:Name="EmptyTitleLabel" TextColor="White" FontAttributes="Bold" HorizontalOptions="Center" />
                <Label x:Name="EmptyMessageLabel" TextColor="#99FFFFFF" HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <CollectionView x:Name="ApprovalsList">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="12" />
                </CollectionView.ItemsLayout>
            </CollectionView>
        </Grid>
    </Grid>
</ContentPage>
