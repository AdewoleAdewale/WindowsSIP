<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="SipCoreMobile.Views.WorkDeskDiscussionPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             BackgroundColor="{StaticResource SIPCoreDarkBlue}"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,Auto,Auto">

        <!-- Header -->
        <HorizontalStackLayout Grid.Row="0" Padding="18,14" Spacing="12">
            <Border StrokeShape="RoundRectangle 21" BackgroundColor="#1AFFFFFF" WidthRequest="42" HeightRequest="42">
                <Label Text="&#xF060;" FontFamily="MaterialIcons" TextColor="White" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center" />
                <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnBackTapped" /></Border.GestureRecognizers>
            </Border>
            <VerticalStackLayout VerticalOptions="Center">
                <Label x:Name="TitleLabel" TextColor="White" FontSize="18" FontAttributes="Bold" LineBreakMode="TailTruncation" />
                <Label Text="Discussion" TextColor="#A6FFFFFF" FontSize="12" />
            </VerticalStackLayout>
        </HorizontalStackLayout>

        <!-- Comments -->
        <ScrollView Grid.Row="1" x:Name="CommentsScroll">
            <VerticalStackLayout x:Name="CommentsList" Padding="16" Spacing="14">
                <!-- Attachments section, prepended above comments -->
                <VerticalStackLayout x:Name="AttachmentsSection" Spacing="8" />
                <Label x:Name="EmptyCommentsLabel" Text="No comments yet." TextColor="#99FFFFFF" IsVisible="False" />
                <VerticalStackLayout x:Name="ThreadsList" Spacing="14" />
            </VerticalStackLayout>
        </ScrollView>

        <!-- Reply bar -->
        <Grid x:Name="ReplyBar" Grid.Row="2" BackgroundColor="#1AFFFFFF" Padding="14,8" IsVisible="False" ColumnDefinitions="4,*,Auto">
            <BoxView Grid.Column="0" Color="{StaticResource SIPCorePrimary}" WidthRequest="4" HeightRequest="36" />
            <VerticalStackLayout Grid.Column="1" Margin="10,0,0,0">
                <Label Text="Replying to" TextColor="{StaticResource SIPCorePrimary}" FontAttributes="Bold" FontSize="11" />
                <Label x:Name="ReplyBarPreview" TextColor="#C2FFFFFF" FontSize="12" LineBreakMode="TailTruncation" />
            </VerticalStackLayout>
            <ImageButton Grid.Column="2" Source="close_icon.png" WidthRequest="18" HeightRequest="18" BackgroundColor="Transparent" Clicked="OnCancelReplyClicked" />
        </Grid>

        <!-- Input bar -->
        <Grid Grid.Row="3" BackgroundColor="#14FFFFFF" Padding="14" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
            <ImageButton Grid.Column="0" Source="attach_icon.png" WidthRequest="24" HeightRequest="24" BackgroundColor="Transparent" Clicked="OnAttachClicked" />
            <Entry x:Name="MessageEntry" Grid.Column="1" Placeholder="Write a comment" TextColor="White" PlaceholderColor="#99FFFFFF" />
            <Border Grid.Column="2" StrokeShape="RoundRectangle 20" BackgroundColor="{StaticResource SIPCorePrimary}" WidthRequest="40" HeightRequest="40">
                <Label Text="&#xF040;" FontFamily="MaterialIcons" TextColor="White" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center" />
                <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnSendTapped" /></Border.GestureRecognizers>
            </Border>
        </Grid>

    </Grid>
</ContentPage>
