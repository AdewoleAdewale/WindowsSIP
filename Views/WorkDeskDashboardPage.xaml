<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="SipCoreMobile.Views.WorkDeskDashboardPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SipCoreMobile.ViewModels"
             x:DataType="vm:WorkDeskViewModel"
             BackgroundColor="{StaticResource SIPCoreDarkBlue}"
             Shell.NavBarIsVisible="False">

    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="18" Spacing="16">

                <!-- Top bar -->
                <HorizontalStackLayout Spacing="12">
                    <Border StrokeShape="RoundRectangle 21" BackgroundColor="#1FFFFFFF" WidthRequest="42" HeightRequest="42">
                        <Label Text="&#xF060;" FontFamily="MaterialIcons" TextColor="White" FontSize="18"
                               HorizontalOptions="Center" VerticalOptions="Center" />
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnBackTapped" />
                        </Border.GestureRecognizers>
                    </Border>
                    <VerticalStackLayout VerticalOptions="Center">
                        <Label Text="SIPCore WorkDesk" TextColor="White" FontSize="20" FontAttributes="Bold" />
                        <Label x:Name="SubtitleLabel" TextColor="#B8FFFFFF" FontSize="12" />
                    </VerticalStackLayout>
                </HorizontalStackLayout>

                <!-- Hero card -->
                <Border StrokeShape="RoundRectangle 26" BackgroundColor="{StaticResource SIPCorePrimary}" Padding="20">
                    <VerticalStackLayout Spacing="4">
                        <Label x:Name="GreetingLabel" TextColor="White" FontSize="17" FontAttributes="Bold" />
                        <Label x:Name="CompanyLabel" TextColor="#E6FFFFFF" FontSize="14" FontAttributes="Bold" />
                        <Label Text="Your work command center" TextColor="#BFFFFFFF" FontSize="12" />

                        <Grid ColumnDefinitions="*,*,*" Margin="0,20,0,0">
                            <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center">
                                <Label x:Name="OpenTasksValue" TextColor="White" FontSize="22" FontAttributes="Bold" HorizontalOptions="Center" />
                                <Label Text="Open" TextColor="#C7FFFFFF" FontSize="12" HorizontalOptions="Center" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center">
                                <Label x:Name="ApprovalsValue" TextColor="White" FontSize="22" FontAttributes="Bold" HorizontalOptions="Center" />
                                <Label Text="Approvals" TextColor="#C7FFFFFF" FontSize="12" HorizontalOptions="Center" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center">
                                <Label x:Name="DueTodayValue" TextColor="White" FontSize="22" FontAttributes="Bold" HorizontalOptions="Center" />
                                <Label Text="Due Today" TextColor="#C7FFFFFF" FontSize="12" HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Quick actions -->
                <VerticalStackLayout Spacing="10">
                    <Label Text="Quick Actions" TextColor="White" FontAttributes="Bold" FontSize="16" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12" RowDefinitions="Auto,Auto" RowSpacing="12">
                        <Border Grid.Row="0" Grid.Column="0" StrokeShape="RoundRectangle 22" BackgroundColor="#17FFFFFF" HeightRequest="92">
                            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="8">
                                <Label Text="&#xF0AE;" FontFamily="MaterialIcons" TextColor="{StaticResource SIPCorePrimary}" FontSize="26" HorizontalOptions="Center" />
                                <Label Text="New Task" TextColor="White" FontAttributes="Bold" HorizontalOptions="Center" />
                            </VerticalStackLayout>
                            <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnCreateTaskTapped" /></Border.GestureRecognizers>
                        </Border>
                        <Border Grid.Row="0" Grid.Column="1" StrokeShape="RoundRectangle 22" BackgroundColor="#17FFFFFF" HeightRequest="92">
                            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="8">
                                <Label Text="&#xF0AE;" FontFamily="MaterialIcons" TextColor="{StaticResource SIPCorePrimary}" FontSize="26" HorizontalOptions="Center" />
                                <Label Text="Tasks" TextColor="White" FontAttributes="Bold" HorizontalOptions="Center" />
                            </VerticalStackLayout>
                            <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnOpenTasksTapped" /></Border.GestureRecognizers>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="0" StrokeShape="RoundRectangle 22" BackgroundColor="#17FFFFFF" HeightRequest="92">
                            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="8">
                                <Label Text="&#xF058;" FontFamily="MaterialIcons" TextColor="{StaticResource SIPCorePrimary}" FontSize="26" HorizontalOptions="Center" />
                                <Label Text="Approvals" TextColor="White" FontAttributes="Bold" HorizontalOptions="Center" />
                            </VerticalStackLayout>
                            <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnOpenApprovalsTapped" /></Border.GestureRecognizers>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="1" StrokeShape="RoundRectangle 22" BackgroundColor="#17FFFFFF" HeightRequest="92">
                            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="8">
                                <Label Text="&#xF0C0;" FontFamily="MaterialIcons" TextColor="{StaticResource SIPCorePrimary}" FontSize="26" HorizontalOptions="Center" />
                                <Label Text="Team" TextColor="White" FontAttributes="Bold" HorizontalOptions="Center" />
                            </VerticalStackLayout>
                            <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnOpenTeamTapped" /></Border.GestureRecognizers>
                        </Border>
                    </Grid>
                </VerticalStackLayout>

                <!-- Live team card -->
                <Border StrokeShape="RoundRectangle 24" BackgroundColor="#14FFFFFF" Padding="18">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                        <Border Grid.Column="0" StrokeShape="RoundRectangle 22" BackgroundColor="#2E22C55E" WidthRequest="44" HeightRequest="44">
                            <Label Text="&#xF012;" FontFamily="MaterialIcons" TextColor="{StaticResource SIPCoreSuccess}" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                            <Label Text="Team Activity Live" TextColor="White" FontAttributes="Bold" />
                            <Label x:Name="TeamOnlineLabel" TextColor="#AEFFFFFF" FontSize="12" />
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="&#xF054;" FontFamily="MaterialIcons" TextColor="#B3FFFFFF" VerticalOptions="Center" />
                    </Grid>
                    <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnOpenTeamTapped" /></Border.GestureRecognizers>
                </Border>

                <!-- Recent activity -->
                <Border StrokeShape="RoundRectangle 24" BackgroundColor="#14FFFFFF" Padding="18">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Recent Activity" TextColor="White" FontAttributes="Bold" />
                        <VerticalStackLayout x:Name="ActivityList" Spacing="8" />
                    </VerticalStackLayout>
                </Border>

                <BoxView HeightRequest="120" Color="Transparent" />
            </VerticalStackLayout>
        </ScrollView>

        <Border StrokeShape="RoundRectangle 28" BackgroundColor="{StaticResource SIPCorePrimary}"
                WidthRequest="56" HeightRequest="56" HorizontalOptions="End" VerticalOptions="End" Margin="0,0,22,22">
            <Label Text="&#xF067;" FontFamily="MaterialIcons" TextColor="White" FontSize="22" HorizontalOptions="Center" VerticalOptions="Center" />
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnCreateTaskTapped" />
            </Border.GestureRecognizers>
        </Border>
    </Grid>
</ContentPage>
