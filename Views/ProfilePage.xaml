<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="SipCoreMobile.Views.ProfilePage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:SipCoreMobile.Controls"
             xmlns:vm="clr-namespace:SipCoreMobile.ViewModels"
             x:DataType="vm:AppStateViewModel"
             BackgroundColor="{StaticResource SIPCoreBackground}"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">
        <controls:SipCoreHeader Grid.Row="0" DrawerRequested="OnDrawerRequested" />

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="22,22,22,30" Spacing="16" MaximumWidthRequest="760">

                <VerticalStackLayout Spacing="4">
                    <Label Text="Profile" FontSize="28" FontAttributes="Bold"
                           TextColor="{StaticResource SIPCoreDarkBlue}" />
                    <Label Text="Manage your SIPCore identity and account information."
                           FontSize="13.5" TextColor="{StaticResource SIPCoreTextSecondary}" />
                </VerticalStackLayout>

                <!-- ══ Identity hero (gradient) ══ -->
                <Border StrokeShape="RoundRectangle 18" StrokeThickness="0" Padding="26,24">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#0E42B3" Offset="0.0" />
                            <GradientStop Color="{StaticResource SIPCorePrimary}" Offset="0.55" />
                            <GradientStop Color="#3D7BFF" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Shadow>
                        <Shadow Brush="{StaticResource SIPCorePrimary}" Opacity="0.3" Radius="16" Offset="0,6" />
                    </Border.Shadow>

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="22">

                        <!-- Avatar with ring -->
                        <Border Grid.Column="0" StrokeShape="RoundRectangle 47"
                                Stroke="#4DFFFFFF" StrokeThickness="2"
                                BackgroundColor="#26FFFFFF"
                                WidthRequest="94" HeightRequest="94" VerticalOptions="Center">
                            <Label x:Name="AvatarLabel" TextColor="White" FontSize="32" FontAttributes="Bold"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>

                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                            <Label x:Name="NameLabel" TextColor="White" FontSize="24" FontAttributes="Bold"
                                   LineBreakMode="TailTruncation" />
                            <Label x:Name="ExtensionLabel" TextColor="#D6E3F8" FontSize="14" />
                            <Border StrokeShape="RoundRectangle 12" StrokeThickness="0"
                                    BackgroundColor="#2EFFFFFF" Padding="12,6"
                                    HorizontalOptions="Start" Margin="0,8,0,0">
                                <Label x:Name="CompanyBadgeLabel" TextColor="White" FontSize="12.5" FontAttributes="Bold" />
                            </Border>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- ══ Account information ══ -->
                <Border StrokeShape="RoundRectangle 14" StrokeThickness="1"
                        Stroke="{StaticResource SIPCoreBorder}" BackgroundColor="{StaticResource SIPCoreCard}"
                        Padding="22,18">
                    <VerticalStackLayout Spacing="0">
                        <Label Text="ACCOUNT INFORMATION" FontSize="11" FontAttributes="Bold"
                               CharacterSpacing="1.5" TextColor="{StaticResource SIPCorePrimary}"
                               Margin="0,0,0,10" />
                        <controls:ProfileInfoRow x:Name="NameRow" Label="Name" />
                        <controls:ProfileInfoRow x:Name="ExtensionRow" Label="Extension" />
                        <controls:ProfileInfoRow x:Name="CompanyRow" Label="Company" />
                        <controls:ProfileInfoRow x:Name="DomainRow" Label="Domain" />
                        <controls:ProfileInfoRow x:Name="StatusRow" Label="Status" />
                        <controls:ProfileInfoRow x:Name="ProductRow" Label="Product" />
                    </VerticalStackLayout>
                </Border>

                <!-- ══ Workspace ══ -->
                <Border StrokeShape="RoundRectangle 14" StrokeThickness="1"
                        Stroke="{StaticResource SIPCoreBorder}" BackgroundColor="{StaticResource SIPCoreCard}"
                        Padding="22,18">
                    <VerticalStackLayout Spacing="0">
                        <Label Text="WORKSPACE" FontSize="11" FontAttributes="Bold"
                               CharacterSpacing="1.5" TextColor="{StaticResource SIPCorePrimary}"
                               Margin="0,0,0,10" />
                        <controls:ProfileInfoRow x:Name="WorkDeskAccessRow" Label="WorkDesk Access" />
                    </VerticalStackLayout>
                </Border>

                <!-- ══ Actions ══ -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,6,0,0">
                    <Button Grid.Column="0" Text="Back to Dialer" Clicked="OnBackToDialerClicked"
                            BackgroundColor="{StaticResource SIPCorePrimary}" TextColor="White"
                            FontAttributes="Bold" FontSize="14"
                            HeightRequest="48" CornerRadius="10" />
                    <Button Grid.Column="1" Text="Logout" Clicked="OnLogoutClicked"
                            BackgroundColor="Transparent" TextColor="{StaticResource SIPCoreDanger}"
                            BorderColor="{StaticResource SIPCoreDanger}" BorderWidth="1"
                            FontAttributes="Bold" FontSize="14"
                            HeightRequest="48" CornerRadius="10" />
                </Grid>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>