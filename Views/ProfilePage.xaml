<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="SipCoreMobile.Views.ProfilePage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:SipCoreMobile.Controls"
             xmlns:vm="clr-namespace:SipCoreMobile.ViewModels"
             x:DataType="vm:AppStateViewModel"
             BackgroundColor="{StaticResource SIPCoreBackground}"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">
        <controls:SipCoreHeader Grid.Row="0" DrawerRequested="OnDrawerRequested" />

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,22,20,30" Spacing="18">

                <VerticalStackLayout Spacing="6">
                    <Label Text="Profile" FontSize="30" FontAttributes="Bold" TextColor="{StaticResource SIPCoreDarkBlue}" />
                    <Label Text="Manage your SIPCore identity and account information."
                           FontSize="14" TextColor="{StaticResource SIPCoreTextSecondary}" />
                </VerticalStackLayout>

                <!-- Identity card -->
                <Border StrokeShape="RoundRectangle 28" BackgroundColor="{StaticResource SIPCorePrimary}" Padding="22">
                    <Border.Shadow>
                        <Shadow Brush="Black" Opacity="0.12" Radius="10" Offset="0,4" />
                    </Border.Shadow>
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="4">
                        <Border StrokeShape="RoundRectangle 48" BackgroundColor="#2EFFFFFF" WidthRequest="96" HeightRequest="96">
                            <Label x:Name="AvatarLabel" TextColor="White" FontSize="34" FontAttributes="Bold"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>

                        <Label x:Name="NameLabel" TextColor="White" FontSize="24" FontAttributes="Bold"
                               HorizontalOptions="Center" Margin="0,16,0,0" />
                        <Label x:Name="ExtensionLabel" TextColor="#D9FFFFFF" FontSize="15" HorizontalOptions="Center" />

                        <Border StrokeShape="RoundRectangle 20" BackgroundColor="#29FFFFFF" Padding="14,7" Margin="0,12,0,0">
                            <Label x:Name="CompanyBadgeLabel" TextColor="White" FontSize="13" FontAttributes="Bold" />
                        </Border>
                    </VerticalStackLayout>
                </Border>

                <!-- Account information card -->
                <Border StrokeShape="RoundRectangle 24" BackgroundColor="{StaticResource SIPCoreCard}" Padding="20">
                    <Border.Shadow>
                        <Shadow Brush="Black" Opacity="0.08" Radius="6" Offset="0,2" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="0">
                        <Label Text="Account Information" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource SIPCoreDarkBlue}" Margin="0,0,0,14" />
                        <controls:ProfileInfoRow x:Name="NameRow" Label="Name" />
                        <controls:ProfileInfoRow x:Name="ExtensionRow" Label="Extension" />
                        <controls:ProfileInfoRow x:Name="CompanyRow" Label="Company" />
                        <controls:ProfileInfoRow x:Name="DomainRow" Label="Domain" />
                        <controls:ProfileInfoRow x:Name="StatusRow" Label="Status" />
                        <controls:ProfileInfoRow x:Name="ProductRow" Label="Product" />
                    </VerticalStackLayout>
                </Border>

                <!-- Workspace card -->
                <Border StrokeShape="RoundRectangle 24" BackgroundColor="{StaticResource SIPCoreCard}" Padding="20">
                    <Border.Shadow>
                        <Shadow Brush="Black" Opacity="0.06" Radius="4" Offset="0,2" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="0">
                        <Label Text="Workspace" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource SIPCoreDarkBlue}" Margin="0,0,0,14" />
                        <controls:ProfileInfoRow x:Name="WorkDeskAccessRow" Label="WorkDesk Access" />
                    </VerticalStackLayout>
                </Border>

                <Button Text="Back to Dialer" Clicked="OnBackToDialerClicked"
                        BackgroundColor="{StaticResource SIPCorePrimary}" TextColor="White"
                        HeightRequest="56" CornerRadius="18" Margin="0,8,0,0" />

                <Button Text="Logout" Clicked="OnLogoutClicked"
                        BackgroundColor="Transparent" TextColor="{StaticResource SIPCoreDanger}"
                        BorderColor="{StaticResource SIPCoreDanger}" BorderWidth="1"
                        HeightRequest="56" CornerRadius="18" />

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
