<?xml version="1.0" encoding="utf-8" ?>
<ContentView x:Class="SipCoreMobile.Controls.SipCoreHeader"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <VerticalStackLayout>
        <Grid BackgroundColor="{StaticResource SIPCoreCard}"
              Padding="16,10" ColumnDefinitions="Auto,Auto,*" ColumnSpacing="12">

            <!-- Menu affordance + logo: one tap target, same OnLogoTapped handler -->
            <Border Grid.Column="0" StrokeShape="RoundRectangle 8" StrokeThickness="0"
                    BackgroundColor="Transparent" Padding="8,6">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnLogoTapped" />
                </Border.GestureRecognizers>
                <HorizontalStackLayout Spacing="10">
                    <Label Text="☰" FontSize="17" VerticalOptions="Center"
                           TextColor="{StaticResource SIPCoreTextSecondary}" />
                    <Image Source="sipcorelogo.png" WidthRequest="30" HeightRequest="30"
                           VerticalOptions="Center">
                        <Image.Clip>
                            <EllipseGeometry Center="15,15" RadiusX="15" RadiusY="15" />
                        </Image.Clip>
                    </Image>
                </HorizontalStackLayout>
            </Border>

            <Label Grid.Column="1" Text="SIPCore" FontSize="16" FontAttributes="Bold"
                   TextColor="{StaticResource SIPCoreDarkBlue}" VerticalOptions="Center" />
        </Grid>
        <BoxView HeightRequest="1" Color="{StaticResource SIPCoreBorder}" />
    </VerticalStackLayout>
</ContentView>