<?xml version="1.0" encoding="utf-8" ?>

<ContentView x:Class="SipCoreMobile.Controls.StatusPulseDot"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             HeightRequest="14" WidthRequest="14">

    <Grid>
        <Ellipse x:Name="GlowRing" Fill="{StaticResource SIPCoreSignalDim}" WidthRequest="14" HeightRequest="14" />
        <Ellipse x:Name="CoreDot" Fill="{StaticResource SIPCoreSignal}" WidthRequest="8" HeightRequest="8"
                  HorizontalOptions="Center" VerticalOptions="Center" />
    </Grid>
</ContentView>
