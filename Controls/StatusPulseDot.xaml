<?xml version="1.0" encoding="utf-8" ?>
<ContentView x:Class="SipCoreMobile.Controls.StatusPulseDot"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             HeightRequest="16" WidthRequest="16">

    <Grid>
        <Ellipse x:Name="GlowRing" Fill="{StaticResource SIPCoreSignalDim}"
                 WidthRequest="16" HeightRequest="16" />
        <Ellipse x:Name="CoreDot" Fill="{StaticResource SIPCoreSignal}"
                 WidthRequest="9" HeightRequest="9"
                 HorizontalOptions="Center" VerticalOptions="Center" />
    </Grid>
</ContentView>