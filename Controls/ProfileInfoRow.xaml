<?xml version="1.0" encoding="utf-8" ?>
<ContentView x:Class="SipCoreMobile.Controls.ProfileInfoRow"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <VerticalStackLayout>
        <Grid ColumnDefinitions="*,Auto" Padding="2,13" ColumnSpacing="16">
            <Label x:Name="LabelText" FontSize="13.5"
                   TextColor="{StaticResource SIPCoreTextSecondary}" VerticalOptions="Center" />
            <Label x:Name="ValueText" Grid.Column="1" FontSize="13.5" FontAttributes="Bold"
                   TextColor="{StaticResource SIPCoreTextPrimary}"
                   HorizontalTextAlignment="End" VerticalOptions="Center"
                   LineBreakMode="TailTruncation" />
        </Grid>
        <BoxView HeightRequest="1" Color="{StaticResource SIPCoreBorder}" Opacity="0.6" />
    </VerticalStackLayout>
</ContentView>