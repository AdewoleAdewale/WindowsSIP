<?xml version="1.0" encoding="utf-8" ?>
<ContentView x:Class="SipCoreMobile.Controls.ProfileInfoRow"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Grid ColumnDefinitions="*,*" Padding="0,10">
        <Label x:Name="LabelText" Grid.Column="0" TextColor="{StaticResource SIPCoreTextSecondary}" />
        <Label x:Name="ValueText" Grid.Column="1" FontAttributes="Bold" TextColor="{StaticResource SIPCoreTextPrimary}"
               HorizontalOptions="End" HorizontalTextAlignment="End" />
    </Grid>
</ContentView>
