<?xml version="1.0" encoding="utf-8" ?>
<ContentView x:Class="SipCoreMobile.Controls.BottomNavBar"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <VerticalStackLayout>
        <BoxView HeightRequest="1" Color="{StaticResource SIPCoreBorder}" />

        <Grid BackgroundColor="{StaticResource SIPCoreCard}"
              Padding="12,8,12,10" ColumnDefinitions="*,*,*,*"
              MaximumWidthRequest="560" HorizontalOptions="Center">

            <VerticalStackLayout Grid.Column="0" Spacing="3" HorizontalOptions="Center">
                <Border x:Name="DialerIconBackground" StrokeShape="RoundRectangle 12"
                        StrokeThickness="0" Padding="18,7" BackgroundColor="Transparent"
                        HorizontalOptions="Center">
                    <Label x:Name="DialerIcon" Text="&#xF095;" FontFamily="MaterialIcons"
                           FontSize="18" TextColor="{StaticResource SIPCoreTextSecondary}" />
                </Border>
                <Label x:Name="DialerLabel" Text="Dialer" FontSize="11"
                       TextColor="{StaticResource SIPCoreTextSecondary}" HorizontalOptions="Center" />
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnDialerTapped" />
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="1" Spacing="3" HorizontalOptions="Center">
                <Border x:Name="ContactsIconBackground" StrokeShape="RoundRectangle 12"
                        StrokeThickness="0" Padding="18,7" BackgroundColor="Transparent"
                        HorizontalOptions="Center">
                    <Label x:Name="ContactsIcon" Text="&#xF0C0;" FontFamily="MaterialIcons"
                           FontSize="18" TextColor="{StaticResource SIPCoreTextSecondary}" />
                </Border>
                <Label x:Name="ContactsLabel" Text="Contacts" FontSize="11"
                       TextColor="{StaticResource SIPCoreTextSecondary}" HorizontalOptions="Center" />
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnContactsTapped" />
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="2" Spacing="3" HorizontalOptions="Center">
                <Border x:Name="MessagesIconBackground" StrokeShape="RoundRectangle 12"
                        StrokeThickness="0" Padding="18,7" BackgroundColor="Transparent"
                        HorizontalOptions="Center">
                    <Label x:Name="MessagesIcon" Text="&#xF0E0;" FontFamily="MaterialIcons"
                           FontSize="18" TextColor="{StaticResource SIPCoreTextSecondary}" />
                </Border>
                <Label x:Name="MessagesLabel" Text="Messages" FontSize="11"
                       TextColor="{StaticResource SIPCoreTextSecondary}" HorizontalOptions="Center" />
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnMessagesTapped" />
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="3" Spacing="3" HorizontalOptions="Center">
                <Border x:Name="HistoryIconBackground" StrokeShape="RoundRectangle 12"
                        StrokeThickness="0" Padding="18,7" BackgroundColor="Transparent"
                        HorizontalOptions="Center">
                    <Label x:Name="HistoryIcon" Text="&#xF1DA;" FontFamily="MaterialIcons"
                           FontSize="18" TextColor="{StaticResource SIPCoreTextSecondary}" />
                </Border>
                <Label x:Name="HistoryLabel" Text="History" FontSize="11"
                       TextColor="{StaticResource SIPCoreTextSecondary}" HorizontalOptions="Center" />
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnHistoryTapped" />
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

        </Grid>
    </VerticalStackLayout>
</ContentView>