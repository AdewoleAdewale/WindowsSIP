<?xml version="1.0" encoding="utf-8" ?>
<ContentView x:Class="SipCoreMobile.Controls.WorkDeskCollapsibleSection"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Border StrokeShape="RoundRectangle 24" BackgroundColor="Black" Padding="10">
        <VerticalStackLayout>
            <Grid ColumnDefinitions="*,Auto">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnHeaderTapped" />
                </Grid.GestureRecognizers>
                <Label x:Name="TitleLabel" Grid.Column="0" TextColor="White" FontAttributes="Bold" FontSize="17" />
                <Label x:Name="ChevronLabel" Grid.Column="1" Text="&#xF078;" FontFamily="MaterialIcons" TextColor="#B3FFFFFF" VerticalOptions="Center" />
            </Grid>
            <VerticalStackLayout x:Name="ContentArea" IsVisible="False" Margin="0,12,0,0" />
        </VerticalStackLayout>
    </Border>
</ContentView>
