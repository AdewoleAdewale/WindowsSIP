<?xml version="1.0" encoding="utf-8" ?>
<ContentView x:Class="SipCoreMobile.Controls.MeetingOptionRow"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Border StrokeShape="RoundRectangle 12" StrokeThickness="1"
            Stroke="{StaticResource SIPCoreBorder}" BackgroundColor="White"
            Padding="12,10" Margin="0,0,0,8">
        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
            <CheckBox x:Name="Checkbox" Color="{StaticResource SIPCorePrimary}"
                      VerticalOptions="Center" CheckedChanged="OnCheckedChanged" />
            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                <Label x:Name="TitleLabel" FontSize="14" FontAttributes="Bold"
                       TextColor="{StaticResource SIPCoreTextPrimary}" />
                <Label x:Name="SubtitleLabel" FontSize="12"
                       TextColor="{StaticResource SIPCoreTextSecondary}" />
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="TapGestureRecognizer_Tapped" />
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>
        </Grid>
    </Border>
</ContentView>