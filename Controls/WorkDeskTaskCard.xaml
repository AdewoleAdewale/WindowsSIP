<?xml version="1.0" encoding="utf-8" ?>
<ContentView x:Class="SipCoreMobile.Controls.WorkDeskTaskCard"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Border StrokeShape="RoundRectangle 14" StrokeThickness="1"
            Stroke="{StaticResource SIPCoreBorder}" Padding="16,14">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FFFFFF" Offset="0.0" />
                <GradientStop Color="#FAFBFF" Offset="0.7" />
                <GradientStop Color="#F2F6FF" Offset="1.0" />
            </LinearGradientBrush>
        </Border.Background>
        <Border.Shadow>
            <Shadow Brush="Black" Opacity="0.05" Radius="6" Offset="0,2" />
        </Border.Shadow>
        <Border.GestureRecognizers>
            <TapGestureRecognizer Tapped="OnCardTapped" />
        </Border.GestureRecognizers>

        <VerticalStackLayout Spacing="12">

            <!-- Header -->
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                <Border x:Name="IconBg" Grid.Column="0" StrokeShape="RoundRectangle 12"
                        StrokeThickness="0" WidthRequest="44" HeightRequest="44">
                    <Label x:Name="IconLabel" Text="&#xF0AE;" FontFamily="MaterialIcons"
                           FontSize="17" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>

                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                    <Label x:Name="TitleLabel" TextColor="{StaticResource SIPCoreTextPrimary}"
                           FontAttributes="Bold" FontSize="15.5"
                           LineBreakMode="TailTruncation" MaxLines="2" />
                    <Label x:Name="CreatorLabel" TextColor="{StaticResource SIPCoreTextSecondary}" FontSize="12" />
                    <Label x:Name="CreatorCompanyLabel" TextColor="#98A2B3" FontSize="11" IsVisible="False" />
                </VerticalStackLayout>

                <Border Grid.Column="2" StrokeShape="RoundRectangle 10" StrokeThickness="1"
                        Stroke="{StaticResource SIPCoreBorder}" BackgroundColor="White"
                        WidthRequest="36" HeightRequest="36" VerticalOptions="Start">
                    <ImageButton x:Name="EditButton" Source="check.png"
                                 WidthRequest="15" HeightRequest="15" Padding="0"
                                 BackgroundColor="Transparent" IsVisible="False"
                                 HorizontalOptions="Center" VerticalOptions="Center"
                                 Clicked="OnEditClicked"
                                 SemanticProperties.Description="Edit task" />
                </Border>
            </Grid>

            <!-- Chips -->
            <HorizontalStackLayout Spacing="8">
                <Border x:Name="StatusChip" StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="9,4">
                    <Label x:Name="StatusLabel" FontSize="10.5" FontAttributes="Bold" CharacterSpacing="0.6" />
                </Border>
                <Border x:Name="PriorityChip" StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="9,4">
                    <Label x:Name="PriorityLabel" FontSize="10.5" FontAttributes="Bold" CharacterSpacing="0.6" />
                </Border>
            </HorizontalStackLayout>

            <ProgressBar x:Name="ProgressIndicator" HeightRequest="4"
                         BackgroundColor="{StaticResource SIPCoreBorder}" />

            <BoxView HeightRequest="1" Color="{StaticResource SIPCoreBorder}" Opacity="0.7" />

            <!-- Meta -->
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="14">
                <VerticalStackLayout Grid.Column="0" Spacing="1">
                    <Label x:Name="TeamLeadLabel" FontSize="12"
                           TextColor="{StaticResource SIPCoreTextPrimary}" LineBreakMode="TailTruncation" />
                    <Label x:Name="TeamLeadCompanyLabel" FontSize="11" TextColor="#98A2B3" IsVisible="False" />
                </VerticalStackLayout>
                <Label Grid.Column="1" x:Name="CommentsCountLabel" FontSize="12"
                       TextColor="{StaticResource SIPCoreTextSecondary}" VerticalOptions="Center" />
                <Label Grid.Column="2" x:Name="AttachmentsCountLabel" FontSize="12"
                       TextColor="{StaticResource SIPCoreTextSecondary}" VerticalOptions="Center" />
            </Grid>
        </VerticalStackLayout>
    </Border>
</ContentView>