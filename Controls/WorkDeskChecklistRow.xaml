<?xml version="1.0" encoding="utf-8" ?>
<ContentView x:Class="SipCoreMobile.Controls.WorkDeskChecklistRow"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Border StrokeShape="RoundRectangle 14" Padding="12" BackgroundColor="#14FFFFFF" Margin="0,0,0,8">
        <Grid ColumnDefinitions="*,Auto">
            <VerticalStackLayout Grid.Column="0">
                <Label x:Name="TitleLabel" TextColor="White" FontAttributes="Bold" FontSize="14" />
                <Label x:Name="DescriptionLabel" TextColor="#99FFFFFF" FontSize="12" IsVisible="False" />
            </VerticalStackLayout>
            <ImageButton Grid.Column="1" Source="close_icon.png" WidthRequest="18" HeightRequest="18"
                         BackgroundColor="Transparent" VerticalOptions="Center" Clicked="OnRemoveClicked" />
        </Grid>
    </Border>
</ContentView>
