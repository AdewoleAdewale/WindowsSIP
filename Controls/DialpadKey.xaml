<?xml version="1.0" encoding="utf-8" ?>

<Grid xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
      xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
      xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
      x:Class="SipCoreMobile.Controls.DialpadKey"
      HeightRequest="76" WidthRequest="76" HorizontalOptions="Center">

    <Border StrokeShape="RoundRectangle 38" BackgroundColor="White">
        <Border.Shadow>
            <Shadow Brush="Black" Opacity="0.06" Radius="4" Offset="0,1" />
        </Border.Shadow>
        <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="0">
            <Label x:Name="DigitLabel" FontSize="29" FontAttributes="Bold"
                   TextColor="{StaticResource SIPCoreTextPrimary}" HorizontalOptions="Center" />
            <Label x:Name="LettersLabel" FontSize="11"
                   TextColor="{StaticResource SIPCoreTextSecondary}" HorizontalOptions="Center" />
        </VerticalStackLayout>

        <Border.Behaviors>
            <toolkit:TouchBehavior x:Name="TouchBehavior" LongPressCompleted="OnLongPressCompleted" />
        </Border.Behaviors>
        <Border.GestureRecognizers>
            <TapGestureRecognizer Tapped="OnTapped" />
        </Border.GestureRecognizers>
    </Border>
</Grid>
