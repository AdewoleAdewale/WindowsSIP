<?xml version="1.0" encoding="utf-8" ?>
<Grid xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
      xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
      xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
      x:Class="SipCoreMobile.Controls.DialpadKey"
      HeightRequest="68" HorizontalOptions="Fill">

    <Border StrokeShape="RoundRectangle 14" StrokeThickness="1"
            Stroke="{StaticResource SIPCoreBorder}"
            BackgroundColor="{StaticResource SIPCoreCard}">
        <Border.Shadow>
            <Shadow Brush="Black" Opacity="0.04" Radius="3" Offset="0,1" />
        </Border.Shadow>

        <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="1">
            <Label x:Name="DigitLabel" FontSize="24" FontAttributes="Bold"
                   TextColor="{StaticResource SIPCoreDarkBlue}" HorizontalOptions="Center" />
            <Label x:Name="LettersLabel" FontSize="9.5" CharacterSpacing="1.5"
                   TextColor="{StaticResource SIPCoreTextSecondary}" HorizontalOptions="Center" />
        </VerticalStackLayout>

        <Border.Behaviors>
            <toolkit:TouchBehavior x:Name="TouchBehavior" LongPressCompleted="OnLongPressCompleted" />
        </Border.Behaviors>
        <Border.GestureRecognizers>
            <TapGestureRecognizer Tapped="OnTapped" />
        </Border.GestureRecognizers>
    </Border>
</Grid>