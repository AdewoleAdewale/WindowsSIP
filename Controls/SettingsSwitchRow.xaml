<?xml version="1.0" encoding="utf-8" ?>
<ContentView x:Class="SipCoreMobile.Controls.SettingsSwitchRow"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Border StrokeShape="RoundRectangle 12" StrokeThickness="1"
            Stroke="{StaticResource SIPCoreBorder}" BackgroundColor="{StaticResource SIPCoreCard}"
            Padding="18,14">
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
            <VerticalStackLayout Grid.Column="0" Spacing="3" VerticalOptions="Center">
                <Label x:Name="TitleLabel" FontSize="15" FontAttributes="Bold"
                       TextColor="{StaticResource SIPCoreTextPrimary}" />
                <Label x:Name="DescriptionLabel" FontSize="12.5"
                       TextColor="{StaticResource SIPCoreTextSecondary}" />
            </VerticalStackLayout>
            <Switch x:Name="ToggleSwitch" Grid.Column="1" VerticalOptions="Center"
                    OnColor="{StaticResource SIPCorePrimary}"
                    ThumbColor="White"
                    Toggled="OnSwitchToggled" />
        </Grid>
    </Border>
</ContentView>