<?xml version="1.0" encoding="utf-8" ?>
<ContentView x:Class="SipCoreMobile.Controls.SettingsSwitchRow"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Border StrokeShape="RoundRectangle 18" BackgroundColor="White" Padding="18">
        <Grid ColumnDefinitions="*,Auto">
            <VerticalStackLayout Grid.Column="0" Spacing="4">
                <Label x:Name="TitleLabel" FontSize="17" FontAttributes="Bold" TextColor="{StaticResource SIPCoreTextPrimary}" />
                <Label x:Name="DescriptionLabel" FontSize="13" TextColor="{StaticResource SIPCoreTextSecondary}" />
            </VerticalStackLayout>

            <Switch x:Name="ToggleSwitch" Grid.Column="1" VerticalOptions="Center" Toggled="OnSwitchToggled" />
        </Grid>
    </Border>
</ContentView>
