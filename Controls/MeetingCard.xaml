<?xml version="1.0" encoding="utf-8" ?>
<ContentView x:Class="SipCoreMobile.Controls.MeetingCard"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:SipCoreMobile.Controls">

    <Border StrokeShape="RoundRectangle 16" StrokeThickness="1"
            Stroke="{StaticResource SIPCoreBorder}" Padding="18,16">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FFFFFF" Offset="0.0" />
                <GradientStop Color="#F5F9FF" Offset="1.0" />
            </LinearGradientBrush>
        </Border.Background>
        <Border.Shadow>
            <Shadow Brush="Black" Opacity="0.06" Radius="8" Offset="0,3" />
        </Border.Shadow>
        <Border.GestureRecognizers>
            <TapGestureRecognizer Tapped="OnCardTapped" />
        </Border.GestureRecognizers>

        <VerticalStackLayout Spacing="14">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                <Border Grid.Column="0" StrokeShape="RoundRectangle 12" StrokeThickness="0"
                        WidthRequest="46" HeightRequest="46">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#0E42B3" Offset="0.0" />
                            <GradientStop Color="#3D7BFF" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Label Text="&#xF03D;" FontFamily="MaterialIcons" TextColor="White" FontSize="16"
                           HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>

                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                    <Label x:Name="TitleLabel" TextColor="{StaticResource SIPCoreDarkBlue}"
                           FontAttributes="Bold" FontSize="16" LineBreakMode="TailTruncation" />
                    <Label x:Name="ConferenceLabel" TextColor="{StaticResource SIPCoreTextSecondary}" FontSize="13" />
                    <Label x:Name="HostLabel" TextColor="#98A2B3" FontSize="12" IsVisible="False" />
                </VerticalStackLayout>

                <controls:MeetingStatusBadge x:Name="StatusBadge" Grid.Column="2" VerticalOptions="Start" />
            </Grid>

            <Border StrokeShape="RoundRectangle 12" StrokeThickness="0" HeightRequest="46">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#0E42B3" Offset="0.0" />
                        <GradientStop Color="{StaticResource SIPCorePrimary}" Offset="0.65" />
                        <GradientStop Color="#2F6BFF" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Shadow>
                    <Shadow Brush="{StaticResource SIPCorePrimary}" Opacity="0.32" Radius="10" Offset="0,4" />
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnJoinClicked" />
                </Border.GestureRecognizers>
                <HorizontalStackLayout Spacing="9" HorizontalOptions="Center" VerticalOptions="Center">
                    <Label Text="▶" TextColor="White" FontSize="12" VerticalOptions="Center" />
                    <Label Text="Join meeting" TextColor="White" FontSize="14.5" FontAttributes="Bold" VerticalOptions="Center" />
                </HorizontalStackLayout>
            </Border>
        </VerticalStackLayout>
    </Border>
</ContentView>