<?xml version="1.0" encoding="utf-8" ?>
<ContentView x:Class="SipCoreMobile.Controls.DrawerMenuItem"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Border x:Name="RowBackground" StrokeShape="RoundRectangle 14" Padding="16,13" BackgroundColor="Transparent">
        <HorizontalStackLayout Spacing="16">
            <Label x:Name="IconLabel" FontFamily="MaterialIcons" FontSize="20" VerticalOptions="Center" />
            <Label x:Name="LabelText" FontSize="15" VerticalOptions="Center" />
        </HorizontalStackLayout>
        <Border.GestureRecognizers>
            <TapGestureRecognizer Tapped="OnTapped" />
        </Border.GestureRecognizers>
    </Border>
</ContentView>
