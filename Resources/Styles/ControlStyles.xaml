<?xml version="1.0" encoding="UTF-8" ?>

<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                     xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Style TargetType="Button">
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Padding" Value="16,12" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="MinimumHeightRequest" Value="46" />
    </Style>

    <Style TargetType="Entry">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="TextColor" Value="{StaticResource SIPCoreTextPrimary}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource SIPCoreTextSecondary}" />
    </Style>

    <Style TargetType="Editor">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="TextColor" Value="{StaticResource SIPCoreTextPrimary}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource SIPCoreTextSecondary}" />
    </Style>

    <Style TargetType="SearchBar">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="PlaceholderColor" Value="{StaticResource SIPCoreTextSecondary}" />
        <Setter Property="CancelButtonColor" Value="{StaticResource SIPCorePrimary}" />
    </Style>

    <Style TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource SIPCoreTextPrimary}" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <Style TargetType="ActivityIndicator">
        <Setter Property="Color" Value="{StaticResource SIPCorePrimary}" />
    </Style>

    <Style TargetType="Switch">
        <Setter Property="OnColor" Value="{StaticResource SIPCorePrimaryLight}" />
        <Setter Property="ThumbColor" Value="{StaticResource SIPCorePrimary}" />
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Color" Value="{StaticResource SIPCorePrimary}" />
    </Style>

    <Style TargetType="Border" x:Key="CardStyle" ApplyToDerivedTypes="False">
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="18" />
            </Setter.Value>
        </Setter>
        <Setter Property="Stroke" Value="Transparent" />
        <Setter Property="BackgroundColor" Value="{StaticResource SIPCoreCard}" />
        <Setter Property="Padding" Value="18" />
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="#1A101828" Radius="14" Opacity="0.5" Offset="0,4" />
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
