<?xml version="1.0" encoding="UTF-8" ?>

<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                     xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Style x:Key="DisplayStyle" TargetType="Label">
        <Setter Property="FontSize" Value="30" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource SIPCoreTextPrimary}" />
        <Setter Property="LineHeight" Value="1.15" />
    </Style>

    <Style x:Key="TitleStyle" TargetType="Label">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource SIPCoreTextPrimary}" />
    </Style>

    <Style x:Key="SubtitleStyle" TargetType="Label">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource SIPCoreTextPrimary}" />
    </Style>

    <Style x:Key="BodyStyle" TargetType="Label">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextColor" Value="{StaticResource SIPCoreTextSecondary}" />
    </Style>

    <Style x:Key="CaptionStyle" TargetType="Label">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextColor" Value="{StaticResource SIPCoreTextSecondary}" />
    </Style>

    <Style x:Key="EyebrowStyle" TargetType="Label">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="CharacterSpacing" Value="1.2" />
        <Setter Property="TextColor" Value="{StaticResource SIPCorePrimary}" />
        <Setter Property="TextTransform" Value="Uppercase" />
    </Style>

    <Style x:Key="EyebrowOnDarkStyle" TargetType="Label" BasedOn="{StaticResource EyebrowStyle}">
        <Setter Property="TextColor" Value="{StaticResource SIPCoreSignal}" />
    </Style>

</ResourceDictionary>
